extern "C" __declspec(dllexport) int __stdcall xlAutoOpen() {
    XLL_SAFE_BLOCK_BEGIN
        ScopedXLOPER12Result xDLL; // Defined here for xlGetName

        // Setup Native Logging
        std::string tempPattern = "";
    std::string projName = "GoldenProj";
    bool isSingleFile = false;
    std::wstring launchLog;
    LaunchConfig cfg;

    
    isSingleFile = true;
    tempPattern = "temp_golden";
    

    std::wstring binDir = GetXllDir();
    
    // Singlefile: ${BIN_DIR} is the extraction directory <temp_dir>\<project>
    // (where ExtractEmbeddedExe unpacks the Go server), so the default
    // logging.dir of ${BIN_DIR} keeps the exe and BOTH logs in one place.
    binDir = ExpandEnvVarsW(L"temp_golden");
    while (!binDir.empty() && (binDir.back() == L'\\' || binDir.back() == L'/')) binDir.pop_back();
    binDir += L"\\GoldenProj";
    

    // Resolve logging.dir into ONE directory shared by both log files:
    // <dir>\<proj>_native.log (this XLL) and <dir>\<proj>_go.log (server stdout).
    std::wstring logDir = L"logs";
    if (logDir == L"XLL_DIR") {
        logDir = GetXllDir();
    } else if (logDir == L"TEMP_DIR") {
        logDir = ExpandEnvVarsW(L"${TEMP}");
    } else {
        // Support placeholders like ${XLL_DIR}, ${BIN_DIR} and ${TEMP}
        ReplaceAll(logDir, L"${XLL_DIR}", GetXllDir());
        ReplaceAll(logDir, L"${BIN_DIR}", binDir);
        logDir = ExpandEnvVarsW(logDir);
    }
    if (logDir.empty()) logDir = binDir;
    while (!logDir.empty() && (logDir.back() == L'\\' || logDir.back() == L'/')) logDir.pop_back();
    std::wstring logPath = logDir + L"\\GoldenProj_native.log";

    std::string logInitError;
    if (!InitLog(logPath, "info", tempPattern, projName, isSingleFile, logInitError)) {
            // If logging fails to initialize, we show a message box but proceed.
            // Logging is critical for debugging but not for core functionality.
            MessageBoxA(NULL, ("Failed to initialize logging: " + logInitError).c_str(), "XLL Initialization Warning", MB_OK | MB_ICONWARNING);
    } else {
            SAFE_LOG_INFO("Logging Initialized Successfully. LogPath: " + WideToUtf8(logPath));
    }

#ifdef SHM_DEBUG
    shm::SetLogHandler(LogHandler);
#endif

    SAFE_LOG_INFO("xlAutoOpen: Loading XLL...");

    xll::CallExcel(xlGetName, xDLL);

    
    // Register the COM/ribbon/RTD destructive-teardown hook so that
    // xll::GracefulTeardownOnce() — driven by the CONFIRMED-shutdown COM events
    // (OnBeginShutdown / OnDisconnection), never by a cancelled quit — runs the
    // ribbon disconnect / class-object revoke / registry unregister exactly once.
    xll::SetGracefulTeardownHook(&GracefulComTeardownHook);
    

    
    // Register RTD Server in Registry
    DllRegisterServer();

    // Also register in memory for immediate access in this process
    rtd::ClassFactory<RtdServer>* pFactory = new rtd::ClassFactory<RtdServer>();
    HRESULT hr_reg = CoRegisterClassObject(GetRtdClsid(), pFactory, CLSCTX_INPROC_SERVER, REGCLS_MULTIPLEUSE, &g_rtdCookie);
    pFactory->Release();

    if (FAILED(hr_reg)) {
        SAFE_LOG_ERROR("CoRegisterClassObject failed: " + std::to_string(hr_reg));
    } else {
        SAFE_LOG_INFO("RTD Server registered in memory successfully.");
    }

    // Create the hidden HWND_MESSAGE window that routes RTD UpdateNotify onto this
    // STA (IMPROVEMENT_BACKLOG §0). MUST be created here, on the STA, BEFORE
    // xll::StartWorker() below — the worker's ProcessRtdUpdate calls
    // xll::SignalRtdUpdate(), which PostMessages to this window, so the window must
    // exist before any RTD update can arrive. Destroyed on the STA in
    // RunDestructiveTeardown (after JoinWorker). See xll_rtd_notify.{h,cpp}.
    xll::CreateRtdNotifyWindow();
    

    // Initialize Shared Memory
    std::string shmName = "GoldenProj";
    
    // Static name for testing/dev
    

    SAFE_LOG_INFO("Initializing Shared Memory: " + shmName);

    // HostConfig: hostSlots, guestSlots.
    shm::HostConfig hostCfg{};
    int workers = 4;
    if (workers < 1) workers = 1;
    hostCfg.numHostSlots = workers * 2 + 2;
    // Guest slots back every guest->host push: streaming RTD updates, one-shot
    // rtd-once results, and grid sends. A connect storm (many RTD topics
    // connecting at once on workbook open) plus a grid send that holds a slot
    // for the duration of its transfer can momentarily saturate this pool. With
    // shm >= v0.7.8 a push waits (up to its timeout) for a free slot instead of
    // failing, but a larger pool keeps that wait short and avoids stranding a
    // one-shot rtd-once cell at #GETTING_DATA under load.
    hostCfg.numGuestSlots = 4;
    hostCfg.shmName = shmName;
    hostCfg.payloadSize = 1024 * 1024; // 1MB

    // Initialize Host (Allocated if null to persist across Probe Unloads)
    if (!g_phost) {
        g_phost = new shm::DirectHost();
    }

    auto initRes = g_host.Init(hostCfg);
    if (initRes.HasError()) {
            std::string err = "Failed to initialize shared memory: " + SHMErrorToString(initRes.GetError());
            SAFE_LOG_ERROR(err);
            MessageBoxA(NULL, err.c_str(), "XLL Error", MB_OK | MB_ICONERROR);
            return 0; // Fail loading
    }

    // Launch Server Process
    
    // Check if already running
    if (g_procInfo.hProcess != NULL) {
        DWORD exitCode = 0;
            if (GetExitCodeProcess(g_procInfo.hProcess, &exitCode) && exitCode == STILL_ACTIVE) {
                SAFE_LOG_INFO("Server process is already running. Skipping launch.");
        } else {
             // Process is dead, clean up handles
             if (g_procInfo.hProcess) CloseHandle(g_procInfo.hProcess);
             if (g_procInfo.hJob) CloseHandle(g_procInfo.hJob);
             if (g_procInfo.hShutdownEvent) CloseHandle(g_procInfo.hShutdownEvent);
             g_procInfo = { 0 };
             goto launch_server;
        }
    } else {
        goto launch_server;
    }
    // Skip launch if running
    goto start_worker;

launch_server:
    // Prepare Launch Config
    cfg.projectName = L"GoldenProj";
    cfg.isSingleFile = isSingleFile;
    cfg.logDir = logDir; // Same resolved logging.dir as the native log
    // server.launch.cwd — placeholders (${BIN_DIR}, ${XLL_DIR}) are expanded by
    // ResolveServerPath (xll_launch.cpp); empty keeps the default (the server
    // executable's directory, i.e. ${BIN_DIR}).
    cfg.cwd = "";
