        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"QJB$";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"OnceScalar", // Procedure
            typeStr.c_str(), // TypeText
            L"OnceScalar", // FunctionText
            L"i,f", // ArgumentText
            1, // MacroType
            L"GoldenProj", // Category
            L"", // Shortcut
            L"", // HelpTopic
            L"", // FunctionHelp
            { // ArgumentHelp
                L"",L"",
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function 'OnceScalar'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function 'OnceScalar' successfully. ID: " + idStr);
        }
    }

    {
        // Register OnceGrid
        // macro:true functions are registered as macro-sheet equivalents ('#',
        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"QQ$";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"OnceGrid", // Procedure
            typeStr.c_str(), // TypeText
            L"OnceGrid", // FunctionText
            L"s", // ArgumentText
            1, // MacroType
            L"GoldenProj", // Category
            L"", // Shortcut
            L"", // HelpTopic
            L"", // FunctionHelp
            { // ArgumentHelp
                L"",
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function 'OnceGrid'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function 'OnceGrid' successfully. ID: " + idStr);
        }
    }

    {
        // Register OnceNumGrid
        // macro:true functions are registered as macro-sheet equivalents ('#',
        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"K%Q$";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"OnceNumGrid", // Procedure
            typeStr.c_str(), // TypeText
            L"OnceNumGrid", // FunctionText
            L"s", // ArgumentText
            1, // MacroType
            L"GoldenProj", // Category
            L"", // Shortcut
            L"", // HelpTopic
            L"", // FunctionHelp
            { // ArgumentHelp
                L"",
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function 'OnceNumGrid'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function 'OnceNumGrid' successfully. ID: " + idStr);
        }
    }

    {
        // Register OnceComposite
        // macro:true functions are registered as macro-sheet equivalents ('#',
        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"QUK%UU$";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"OnceComposite", // Procedure
            typeStr.c_str(), // TypeText
            L"OnceComposite", // FunctionText
            L"g,ng,r,a", // ArgumentText
            1, // MacroType
            L"GoldenProj", // Category
            L"", // Shortcut
            L"", // HelpTopic
            L"", // FunctionHelp
            { // ArgumentHelp
                L"",L"",L"",L"",
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function 'OnceComposite'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function 'OnceComposite' successfully. ID: " + idStr);
        }
    }

    {
        // Register OnceMemoize
        // macro:true functions are registered as macro-sheet equivalents ('#',
        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"QJ$";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"OnceMemoize", // Procedure
            typeStr.c_str(), // TypeText
            L"OnceMemoize", // FunctionText
            L"i", // ArgumentText
            1, // MacroType
            L"GoldenProj", // Category
            L"", // Shortcut
            L"", // HelpTopic
            L"", // FunctionHelp
            { // ArgumentHelp
                L"",
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function 'OnceMemoize'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function 'OnceMemoize' successfully. ID: " + idStr);
        }
    }

    {
        // Register OnceTTL
        // macro:true functions are registered as macro-sheet equivalents ('#',
        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"QJ$";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"OnceTTL", // Procedure
            typeStr.c_str(), // TypeText
            L"OnceTTL", // FunctionText
            L"i", // ArgumentText
            1, // MacroType
            L"GoldenProj", // Category
            L"", // Shortcut
            L"", // HelpTopic
            L"", // FunctionHelp
            { // ArgumentHelp
                L"",
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function 'OnceTTL'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function 'OnceTTL' successfully. ID: " + idStr);
        }
    }


    
    // Register XLL Commands (macroType=2). Mirrors the function loop above but
    // with no args/category and a Ctrl+Shift+<letter> shortcut. Command names
    // were registered above so a shortcut-fired proc resolves its name.
    
    
    {
        // Register command Cmd_RunReport
        ScopedXLOPER12Result xRegId;
        int regRes = xll::RegisterFunction(
            *xDLL,
            L"Cmd_RunReport", // Procedure (exported symbol)
            L"J", // TypeText: "J" = 4-byte signed int (matches the `int` Cmd_ export return; macroType=2 ignores the value). See §19.2.
            L"RunReport", // FunctionText: name typed in the Alt+F8 dialog
            L"", // ArgumentText: commands take none
            2, // MacroType 2 = command
            L"", // Category (unused for commands)
            L"", // Shortcut letter -> Ctrl+Shift+<letter>
            L"", // HelpTopic
            L"Runs the report", // FunctionHelp
            {}, // ArgumentHelp
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register command 'RunReport'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered command 'RunReport' successfully. ID: " + idStr);
        }
    }
    
    

    

        SAFE_LOG_INFO("xlAutoOpen: Initialization complete. Returning 1.");
        return 1;
    XLL_SAFE_BLOCK_END(0)
}

// Event Handlers

extern "C" __declspec(dllexport) void __stdcall OnRecalc() {
    
    
    
    // A user-renamed CalculationEnded handler still owns ALL system-side
    // calc-end work: RefCache clear, rtd-once ClearNonMemoized, the date
    // auto-format drain (DrainAndApplyDateFormats), AND the MSG_CALCULATION_ENDED
    // round-trip that ultimately invokes the user's Go handler (OnRecalc).
    // HandleCalculationEnded() does all of this. Without this call the drain
    // never runs — dates returned by UDFs stay as raw serials and the user's
    // own Go handler never fires. (Regression fixed: previously this named-event
    // stub only logged, and the built-in CalculationEnded() macro that calls
    // HandleCalculationEnded was suppressed whenever a user handler existed.)
    HandleCalculationEnded();
    
}



// User defined handler exists


// Calc-end deferred command runner. Registered as a macro (macroType=2) in
// xlAutoOpen and scheduled via xlcOnTime from HandleCalculationEnded. Excel
// dispatches it on the STA thread at an idle point — OUTSIDE the
// xleventCalculationEnded callback and after any in-flight recalc / rtd-once
// topic teardown has settled — which is where it is safe to run the cell
// mutations (xlSet) and the date auto-format (COM Range.NumberFormat applied
// off-selection; see src/xll_date_format.cpp). The exported symbol name
// MUST match xll::DeferredRunnerMacroName(). Returns short (TypeText "I").
extern "C" __declspec(dllexport) short __stdcall __xllgen_RunDeferredCalcEnd() {
    XLL_SAFE_BLOCK_BEGIN
        xll::RunDeferredCalcEndCommands();
    XLL_SAFE_BLOCK_END(0)
    return 1;
}

// User Functions

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall SyncStr(LPXLOPER12 s) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: SyncStr");

    
    
    
    
    

    
    // Cache Lookup
    xll::CacheConfig cacheConfig;
    cacheConfig.enabled = true;
    cacheConfig.ttl = std::chrono::milliseconds(600000);
    cacheConfig.jitter = std::chrono::milliseconds(0);

    // Prepare temporary XLOPERs for non-pointer arguments
    std::vector<XLOPER12> tempArgs(1);
    std::vector<LPXLOPER12> cacheArgs;
    cacheArgs.reserve(1);

    
    {
        XLOPER12& xArg = tempArgs[0];
        
        // A `string` arg is registered LPXLOPER12 (ArgCppType), so s is
        // already a well-formed Excel-owned XLOPER12* (xltypeStr / Missing / Err
        // for an empty cell). Push it directly like grid/range/any —
        // MakeCacheKey's SerializeXLOPER content-hashes xltypeStr via
        // PascalToWString, so the key already tracks the string's content. (The
        // old branch called CreateStringXLOPER, which is defined nowhere and so
        // never compiled whenever a cache-enabled function had a string arg.)
        (void)xArg;
        cacheArgs.push_back(s);
        
    }
    

    std::string cacheKey = xll::MakeCacheKey("SyncStr", cacheArgs);
    

    // (No temporary string allocations to clean up: string cache args are the
    // Excel-owned XLOPER12* pushed directly above, not DLL-allocated copies.)

    std::vector<uint8_t> cachedData;
    if (xll::CacheManager::Instance().Get(cacheKey, cachedData)) {
        // Deserialize response
        auto resp = flatbuffers::GetRoot<ipc::SyncStrResponse>(cachedData.data());

        // Surface a handler error to the cell as text (mirrors the async path in
        // xll_async.cpp). The Go server writes Response.error when the handler
        // returns a non-nil error; without this the errored response falls through
        // to resp->result() and the cell shows the shared #VALUE! sentinel with the
        // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
        // it is excluded and keeps its empty-grid error result.
        if (resp->error() && resp->error()->size() > 0) {
            std::wstring werr = StringToWString(resp->error()->str());
            return NewExcelString(werr.c_str());
        }
        
        std::wstring wres = StringToWString(resp->result()->str());
        return NewExcelString(wres.c_str());
        
    }
    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    auto arg0 = builder.CreateString((s->xltype == xltypeStr) ? ConvertExcelString(s->val.str) : "");
    
    

    

    

    ipc::SyncStrRequestBuilder reqBuilder(builder);
    
    
    reqBuilder.add_s(arg0);
    
    

    
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Sync Send
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType)140, 2000);

    if (res.HasError()) {
            
            return &g_xlErrValue;
            
    }

    auto resp = flatbuffers::GetRoot<ipc::SyncStrResponse>(slot.GetRespBuffer());

    
    // Store in cache
    {
        int32_t respSize = slot.GetRespSize();
        if (respSize > 0) {
                std::vector<uint8_t> response(slot.GetRespBuffer(), slot.GetRespBuffer() + respSize);
                xll::CacheManager::Instance().Put(cacheKey, response, cacheConfig);
        }
    }
    

    // Surface a handler error to the cell as text (mirrors the async path in
    // xll_async.cpp). The Go server writes Response.error when the handler
    // returns a non-nil error; without this the errored response falls through
    // to resp->result() and the cell shows the shared #VALUE! sentinel with the
    // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
    // it is excluded and keeps its empty-grid error result.
    if (resp->error() && resp->error()->size() > 0) {
        std::wstring werr = StringToWString(resp->error()->str());
        return NewExcelString(werr.c_str());
    }
    
    std::wstring wres = StringToWString(resp->result()->str());
    return NewExcelString(wres.c_str());
    
    
    
}

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall SyncInt(int32_t i) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: SyncInt");

    
    
    
    
    

    
    // Cache Lookup
    xll::CacheConfig cacheConfig;
    cacheConfig.enabled = true;
    cacheConfig.ttl = std::chrono::milliseconds(600000);
    cacheConfig.jitter = std::chrono::milliseconds(0);

    // Prepare temporary XLOPERs for non-pointer arguments
    std::vector<XLOPER12> tempArgs(1);
    std::vector<LPXLOPER12> cacheArgs;
    cacheArgs.reserve(1);

    
    {
        XLOPER12& xArg = tempArgs[0];
        
        xArg.xltype = xltypeInt;
        xArg.val.w = i;
        cacheArgs.push_back(&xArg);
        
    }
    

    std::string cacheKey = xll::MakeCacheKey("SyncInt", cacheArgs);
    

    // (No temporary string allocations to clean up: string cache args are the
    // Excel-owned XLOPER12* pushed directly above, not DLL-allocated copies.)

    std::vector<uint8_t> cachedData;
    if (xll::CacheManager::Instance().Get(cacheKey, cachedData)) {
        // Deserialize response
        auto resp = flatbuffers::GetRoot<ipc::SyncIntResponse>(cachedData.data());

        // Surface a handler error to the cell as text (mirrors the async path in
        // xll_async.cpp). The Go server writes Response.error when the handler
        // returns a non-nil error; without this the errored response falls through
        // to resp->result() and the cell shows the shared #VALUE! sentinel with the
        // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
        // it is excluded and keeps its empty-grid error result.
        if (resp->error() && resp->error()->size() > 0) {
            std::wstring werr = StringToWString(resp->error()->str());
            return NewExcelString(werr.c_str());
        }
        
        static thread_local XLOPER12 xRes;
        xRes.xltype = xltypeInt;
        xRes.val.w = resp->result();
        return &xRes;
        
    }
    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    

    

    

    ipc::SyncIntRequestBuilder reqBuilder(builder);
    
    
    
    reqBuilder.add_i(i);
    
    

    
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Sync Send
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType)141, 2000);

    if (res.HasError()) {
            
            return &g_xlErrValue;
            
    }

    auto resp = flatbuffers::GetRoot<ipc::SyncIntResponse>(slot.GetRespBuffer());

    
    // Store in cache
    {
        int32_t respSize = slot.GetRespSize();
        if (respSize > 0) {
                std::vector<uint8_t> response(slot.GetRespBuffer(), slot.GetRespBuffer() + respSize);
                xll::CacheManager::Instance().Put(cacheKey, response, cacheConfig);
        }
    }
    

    // Surface a handler error to the cell as text (mirrors the async path in
    // xll_async.cpp). The Go server writes Response.error when the handler
    // returns a non-nil error; without this the errored response falls through
    // to resp->result() and the cell shows the shared #VALUE! sentinel with the
    // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
    // it is excluded and keeps its empty-grid error result.
    if (resp->error() && resp->error()->size() > 0) {
        std::wstring werr = StringToWString(resp->error()->str());
        return NewExcelString(werr.c_str());
    }
    
    static thread_local XLOPER12 xRes;
    xRes.xltype = xltypeInt;
    xRes.val.w = resp->result();
    return &xRes;
    
    
    
}

