extern "C" __declspec(dllexport) void __stdcall AsyncGrid(LPXLOPER12 g, LPXLOPER12 asyncHandle) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Async UDFs return void; Excel was told the result would arrive via
        // xlAsyncReturn. With the host gone there is nothing to send — bail.
        return;
        
    }

    SAFE_LOG_DEBUG("Func Entry: AsyncGrid");

    
    
    
    
    

    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    // A `grid` arg is registered `U` (§19.2), so Excel passes a REFERENCE
    // (xltypeRef/SRef) for a range like A1:B2 — NOT an xltypeMulti. Plain
    // ConvertGrid only understands xltypeMulti and would coin a degenerate 1x1
    // Nil grid for a reference (the Go handler then reads an empty grid →
    // SumGrid==0). Route through xll::ConvertGridArg, which xlCoerce's the ref
    // to its cell VALUES first (mirrors the rtd/rtd-once content-hash path).
    // An array LITERAL ({1,2;3,4}) already arrives as xltypeMulti and passes
    // through unchanged.
    bool gridCoerceOk0 = true;
    auto arg0 = xll::ConvertGridArg(g, builder, &gridCoerceOk0);
    if (!gridCoerceOk0) {
        // xlCoerce failed (xlretUncalced mid-calc, cross-sheet restriction, …).
        // Do NOT ship a degenerate 1x1 Nil grid — surface the same error the
        // SHM-failure path below returns so the cell shows #VALUE! and Excel
        // re-drives the UDF on the next recalc pass (precedents calc first for
        // a `$`-registered function, so this is genuinely exceptional).
        SAFE_LOG_WARN("AsyncGrid: grid arg g coerce failed; returning error sentinel");
        
        XLOPER12 xErr{}; // zero-init: Excel reads only val.err for xltypeErr; keeps padding deterministic
        xErr.xltype = xltypeErr;
        xErr.val.err = xlerrValue;
        xll::CallExcel(xlAsyncReturn, nullptr, (LPXLOPER12)asyncHandle, &xErr);
        return;
        
    }
    
    

    

    
    auto asyncHandle_vec = builder.CreateVector((const uint8_t*)asyncHandle, sizeof(XLOPER12));
    

    ipc::AsyncGridRequestBuilder reqBuilder(builder);
    
    
    reqBuilder.add_g(arg0);
    
    

    
    
    reqBuilder.add_async_handle(asyncHandle_vec);
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Async Send
    SAFE_LOG_DEBUG("Async Send Start: AsyncGrid");
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType)154, 2000);
    SAFE_LOG_DEBUG("Async Send End: AsyncGrid");

    if (res.HasError()) {
            std::string err = "Async send failed: " + SHMErrorToString(res.GetError());
            SAFE_LOG_ERROR(err);
            XLOPER12 xErr;
            xErr.xltype = xltypeErr;
            xErr.val.err = xlerrValue;
            xll::CallExcel(xlAsyncReturn, nullptr, (LPXLOPER12)asyncHandle, &xErr);
            return;
    }
    SAFE_LOG_DEBUG("Func Exit: AsyncGrid");
    return;
    
    
}

