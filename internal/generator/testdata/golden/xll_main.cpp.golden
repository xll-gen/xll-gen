// XLL command procedures (macroType=2). Invoked via Ctrl+Shift shortcut or a
// typed name in the Alt+F8 dialog; ribbon clicks go through
// RibbonAddIn::Invoke instead. Same fire-and-forget dispatch — a command
// proc must never block Excel's UI thread waiting on the Go handler.

extern "C" __declspec(dllexport) int __stdcall Cmd_RunReport() {
    XLL_SAFE_BLOCK_BEGIN
        xll::ribbon::SendCommandInvoke("RunReport", "");
    XLL_SAFE_BLOCK_END(0)
    return 1;
}


