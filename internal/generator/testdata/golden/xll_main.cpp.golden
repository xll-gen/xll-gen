        std::wstring werr = StringToWString(resp->error()->str());
        return NewExcelString(werr.c_str());
    }
    
    xll::ScheduleDateFormatsForCaller(resp->result());
    return GridToXLOPER12(resp->result());
    
    
    
}

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall CallerMacroRange(LPXLOPER12 r) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: CallerMacroRange");

    
    
    
    
    

    
    // Cache Lookup
    xll::CacheConfig cacheConfig;
    cacheConfig.enabled = true;
    cacheConfig.ttl = std::chrono::milliseconds(600000);
    cacheConfig.jitter = std::chrono::milliseconds(0);

    // Prepare temporary XLOPERs for non-pointer arguments
    std::vector<XLOPER12> tempArgs(1);
    std::vector<LPXLOPER12> cacheArgs;
    cacheArgs.reserve(1);

    
    {
        XLOPER12& xArg = tempArgs[0];
        
        // grid/range/any are already LPXLOPER12; MakeCacheKey content-hashes
        // them (SerializeXLOPER for value arrays, GetOrComputeRefHash for the
        // U-passed range references), so the identity cast is well-formed and
        // the cache key already tracks their content.
        cacheArgs.push_back((LPXLOPER12)r);
        
    }
    

    std::string cacheKey = xll::MakeCacheKey("CallerMacroRange", cacheArgs);
    

    // (No temporary string allocations to clean up: string cache args are the
    // Excel-owned XLOPER12* pushed directly above, not DLL-allocated copies.)

    std::vector<uint8_t> cachedData;
    if (xll::CacheManager::Instance().Get(cacheKey, cachedData)) {
        // Deserialize response
        auto resp = flatbuffers::GetRoot<ipc::CallerMacroRangeResponse>(cachedData.data());

        // Surface a handler error to the cell as text (mirrors the async path in
        // xll_async.cpp). The Go server writes Response.error when the handler
        // returns a non-nil error; without this the errored response falls through
        // to resp->result() and the cell shows the shared #VALUE! sentinel with the
        // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
        // it is excluded and keeps its empty-grid error result.
        if (resp->error() && resp->error()->size() > 0) {
            std::wstring werr = StringToWString(resp->error()->str());
            return NewExcelString(werr.c_str());
        }
        
        static thread_local XLOPER12 xRes;
        xRes.xltype = xltypeInt;
        xRes.val.w = resp->result();
        return &xRes;
        
    }
    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    auto arg0 = ConvertRange(r, builder);
    
    

    
    flatbuffers::Offset<protocol::Range> caller_off = 0;
    {
        ScopedXLOPER12 xCaller;
        if (xll::CallExcel(xlfCaller, xCaller) == xlretSuccess) {
            std::string callerFormat = "";
            
            // macro:true → the function is a macro-sheet equivalent ('#'), so
            // the wrapper may call the macro-only xlfGetCell to fetch the
            // caller's number-format string (type 7) into Range.Format().
            XLOPER12 xType; xType.xltype = xltypeInt; xType.val.w = 7;
            // ScopedXLOPER12Result (not ScopedXLOPER12): xlfGetCell returns an
            // Excel-allocated xltypeStr that must be released with xlFree —
            // the Result destructor does that; plain ScopedXLOPER12 leaked it
            // on every macro caller-aware call.
            ScopedXLOPER12Result xFormat;
            if (xll::CallExcel(xlfGetCell, xFormat, &xType, xCaller) == xlretSuccess) {
                if (xFormat.get()->xltype == xltypeStr) {
                        callerFormat = ConvertExcelString(xFormat.get()->val.str);
                }
            }
            
            // caller:true without macro:true is position-only — xlfCaller is
            // callable from any XLL function, but xlfGetCell is not, so the
            // number format is left empty here (Range.Format() == "").
            caller_off = ConvertRange(xCaller.get(), builder, callerFormat);
        }
    }
    

    

    ipc::CallerMacroRangeRequestBuilder reqBuilder(builder);
    
    
    reqBuilder.add_r(arg0);
    
    

    
    if (caller_off.o != 0) reqBuilder.add_caller(caller_off);
    
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Sync Send
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType)151, 2000);

    if (res.HasError()) {
            
            return &g_xlErrValue;
            
    }

    auto resp = flatbuffers::GetRoot<ipc::CallerMacroRangeResponse>(slot.GetRespBuffer());

    
    // Store in cache
    {
        int32_t respSize = slot.GetRespSize();
        if (respSize > 0) {
                std::vector<uint8_t> response(slot.GetRespBuffer(), slot.GetRespBuffer() + respSize);
                xll::CacheManager::Instance().Put(cacheKey, response, cacheConfig);
        }
    }
    

    // Surface a handler error to the cell as text (mirrors the async path in
    // xll_async.cpp). The Go server writes Response.error when the handler
    // returns a non-nil error; without this the errored response falls through
    // to resp->result() and the cell shows the shared #VALUE! sentinel with the
    // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
    // it is excluded and keeps its empty-grid error result.
    if (resp->error() && resp->error()->size() > 0) {
        std::wstring werr = StringToWString(resp->error()->str());
        return NewExcelString(werr.c_str());
    }
    
    static thread_local XLOPER12 xRes;
    xRes.xltype = xltypeInt;
    xRes.val.w = resp->result();
    return &xRes;
    
    
    
}

extern "C" __declspec(dllexport) void __stdcall AsyncStr(LPXLOPER12 s, LPXLOPER12 asyncHandle) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Async UDFs return void; Excel was told the result would arrive via
        // xlAsyncReturn. With the host gone there is nothing to send — bail.
        return;
        
    }

    SAFE_LOG_DEBUG("Func Entry: AsyncStr");

    
    
    
    
    

    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    auto arg0 = builder.CreateString((s->xltype == xltypeStr) ? ConvertExcelString(s->val.str) : "");
    
    

    

    
    auto asyncHandle_vec = builder.CreateVector((const uint8_t*)asyncHandle, sizeof(XLOPER12));
    

    ipc::AsyncStrRequestBuilder reqBuilder(builder);
    
    
    reqBuilder.add_s(arg0);
    
    

    
    
    reqBuilder.add_async_handle(asyncHandle_vec);
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Async Send
    SAFE_LOG_DEBUG("Async Send Start: AsyncStr");
