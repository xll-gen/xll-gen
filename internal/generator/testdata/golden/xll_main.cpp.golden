extern "C" __declspec(dllexport) LPXLOPER12 __stdcall SyncGrid(LPXLOPER12 g) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: SyncGrid");

    
    
    
    
    

    
    // Cache Lookup
    xll::CacheConfig cacheConfig;
    cacheConfig.enabled = true;
    cacheConfig.ttl = std::chrono::milliseconds(600000);
    cacheConfig.jitter = std::chrono::milliseconds(0);

    // Prepare temporary XLOPERs for non-pointer arguments
    std::vector<XLOPER12> tempArgs(1);
    std::vector<LPXLOPER12> cacheArgs;
    cacheArgs.reserve(1);

    
    {
        XLOPER12& xArg = tempArgs[0];
        
        // grid/range/any are already LPXLOPER12; MakeCacheKey content-hashes
        // them (SerializeXLOPER for value arrays, GetOrComputeRefHash for the
        // U-passed range references), so the identity cast is well-formed and
        // the cache key already tracks their content.
        cacheArgs.push_back((LPXLOPER12)g);
        
    }
    

    std::string cacheKey = xll::MakeCacheKey("SyncGrid", cacheArgs);
    

    // (No temporary string allocations to clean up: string cache args are the
    // Excel-owned XLOPER12* pushed directly above, not DLL-allocated copies.)

    std::vector<uint8_t> cachedData;
    if (xll::CacheManager::Instance().Get(cacheKey, cachedData)) {
        // Deserialize response
        auto resp = flatbuffers::GetRoot<ipc::SyncGridResponse>(cachedData.data());

        // Surface a handler error to the cell as text (mirrors the async path in
        // xll_async.cpp). The Go server writes Response.error when the handler
        // returns a non-nil error; without this the errored response falls through
        // to resp->result() and the cell shows the shared #VALUE! sentinel with the
        // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
        // it is excluded and keeps its empty-grid error result.
        if (resp->error() && resp->error()->size() > 0) {
            std::wstring werr = StringToWString(resp->error()->str());
            return NewExcelString(werr.c_str());
        }
        
        xll::ScheduleDateFormatsForCaller(resp->result());
        return GridToXLOPER12(resp->result());
        
    }
    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    // A `grid` arg is registered `U` (§19.2), so Excel passes a REFERENCE
    // (xltypeRef/SRef) for a range like A1:B2 — NOT an xltypeMulti. Plain
    // ConvertGrid only understands xltypeMulti and would coin a degenerate 1x1
    // Nil grid for a reference (the Go handler then reads an empty grid →
    // SumGrid==0). Route through xll::ConvertGridArg, which xlCoerce's the ref
    // to its cell VALUES first (mirrors the rtd/rtd-once content-hash path).
    // An array LITERAL ({1,2;3,4}) already arrives as xltypeMulti and passes
    // through unchanged.
    bool gridCoerceOk0 = true;
    auto arg0 = xll::ConvertGridArg(g, builder, &gridCoerceOk0);
    if (!gridCoerceOk0) {
        // xlCoerce failed (xlretUncalced mid-calc, cross-sheet restriction, …).
        // Do NOT ship a degenerate 1x1 Nil grid — surface the same error the
        // SHM-failure path below returns so the cell shows #VALUE! and Excel
        // re-drives the UDF on the next recalc pass (precedents calc first for
        // a `$`-registered function, so this is genuinely exceptional).
        SAFE_LOG_WARN("SyncGrid: grid arg g coerce failed; returning error sentinel");
        
        return &g_xlErrValue;
        
    }
    
    

    

    

    ipc::SyncGridRequestBuilder reqBuilder(builder);
    
    
    reqBuilder.add_g(arg0);
    
    

    
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Sync Send
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType)145, 2000);

    if (res.HasError()) {
            
            return &g_xlErrValue;
            
    }

    auto resp = flatbuffers::GetRoot<ipc::SyncGridResponse>(slot.GetRespBuffer());

    
    // Store in cache
    {
        int32_t respSize = slot.GetRespSize();
        if (respSize > 0) {
                std::vector<uint8_t> response(slot.GetRespBuffer(), slot.GetRespBuffer() + respSize);
                xll::CacheManager::Instance().Put(cacheKey, response, cacheConfig);
        }
    }
    

    // Surface a handler error to the cell as text (mirrors the async path in
    // xll_async.cpp). The Go server writes Response.error when the handler
    // returns a non-nil error; without this the errored response falls through
    // to resp->result() and the cell shows the shared #VALUE! sentinel with the
    // message only in the Go log. numgrid (FP12*/K%) cannot carry a string, so
    // it is excluded and keeps its empty-grid error result.
    if (resp->error() && resp->error()->size() > 0) {
        std::wstring werr = StringToWString(resp->error()->str());
        return NewExcelString(werr.c_str());
    }
    
    xll::ScheduleDateFormatsForCaller(resp->result());
    return GridToXLOPER12(resp->result());
    
    
    
}

extern "C" __declspec(dllexport) FP12* __stdcall SyncNumGrid(FP12* ng) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // FP12* (K%) functions cannot return an XLOPER12 sentinel; a null
        // FP12* is the established error convention (NumGridToFP12's own
        // error paths return nullptr; Excel renders #NUM!). This covers BOTH
        // sync numgrid AND rtd-once numgrid — both export FP12* (K%), so the
        // &g_xlErrValue (LPXLOPER12) sentinel below would be a type mismatch.
        return nullptr;
        
    }

    SAFE_LOG_DEBUG("Func Entry: SyncNumGrid");

    
    
    
    
    

    
    // Cache Lookup
    xll::CacheConfig cacheConfig;
    cacheConfig.enabled = true;
    cacheConfig.ttl = std::chrono::milliseconds(600000);
    cacheConfig.jitter = std::chrono::milliseconds(0);

    // Prepare temporary XLOPERs for non-pointer arguments
    std::vector<XLOPER12> tempArgs(1);
    std::vector<LPXLOPER12> cacheArgs;
    cacheArgs.reserve(1);

    
    {
        XLOPER12& xArg = tempArgs[0];
        
        // numgrid is an FP12* (not an XLOPER12), so it cannot enter the
        // LPXLOPER12 cacheArgs vector — reinterpret-casting FP12* to LPXLOPER12
        // would make MakeCacheKey read the FP12 double payload as an XLOPER
        // (garbage xltype -> silent mis-key or a bogus lpmref deref/AV). Its
        // content hash is folded into cacheKey AFTER MakeCacheKey below via the
        // same ContentHashTokenFP12 the RTD path uses (§19.3).
        (void)xArg;
        
    }
    

    std::string cacheKey = xll::MakeCacheKey("SyncNumGrid", cacheArgs);
    
    // Fold this numgrid (FP12*) arg's content hash into the cache key. A numgrid
    // arg cannot enter the LPXLOPER12 cacheArgs vector, so MakeCacheKey never
    // saw it; append the same ContentHashTokenFP12 token the RTD content-hash
    // path uses (§19.3) so distinct grids get distinct keys and identical grids
    // share one. Without this the numgrid arg would be invisible to the key.
    cacheKey += "|numgrid:" + xll::ContentHashTokenFP12(ng);
    

    // (No temporary string allocations to clean up: string cache args are the
    // Excel-owned XLOPER12* pushed directly above, not DLL-allocated copies.)

    std::vector<uint8_t> cachedData;
    if (xll::CacheManager::Instance().Get(cacheKey, cachedData)) {
        // Deserialize response
        auto resp = flatbuffers::GetRoot<ipc::SyncNumGridResponse>(cachedData.data());

        
        return NumGridToFP12(resp->result());
        
    }
    

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    
    
    auto arg0 = ConvertNumGrid(ng, builder);
    
    

    

    

    ipc::SyncNumGridRequestBuilder reqBuilder(builder);
    
    
    reqBuilder.add_ng(arg0);
    
    

    
    

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    
    // Sync Send
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType)146, 2000);

    if (res.HasError()) {
            
            // FP12* (K%) error convention: null FP12* (matches NumGridToFP12).
            return nullptr;
            
    }

    auto resp = flatbuffers::GetRoot<ipc::SyncNumGridResponse>(slot.GetRespBuffer());

    
    // Store in cache
    {
        int32_t respSize = slot.GetRespSize();
        if (respSize > 0) {
                std::vector<uint8_t> response(slot.GetRespBuffer(), slot.GetRespBuffer() + respSize);
                xll::CacheManager::Instance().Put(cacheKey, response, cacheConfig);
        }
    }
    

    
    return NumGridToFP12(resp->result());
    
    
    
}

