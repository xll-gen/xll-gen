extern "C" __declspec(dllexport) LPXLOPER12 __stdcall RtdScalars(int32_t i, LPXLOPER12 s, double f) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: RtdScalars");

    
    // RTD Wrapper Implementation
    static thread_local XLOPER12 xRes;

    // Convert arguments to strings for RTD Topics
    // Topic 0: Function Name
    std::wstring t0 = L"RtdScalars";

    
    std::wstring t1;
    {
        
        t1 = std::to_wstring(i);
        
    }
    
    std::wstring t2;
    {
        
        if (s->xltype == xltypeStr) {
            t2 = PascalToWString(s->val.str);
        }
        
    }
    
    std::wstring t3;
    {
        
        // %.17g round-trip (NOT std::to_wstring's 6-digit %f): the topic string is
        // the ONLY channel for a scalar value, so truncation merges distinct
        // arguments onto one topic. Go parses %.17g via strconv.ParseFloat.
        t3 = FormatDoubleRoundTrip(f);
        
    }
    

    // Call Excel RTD(ProgID, Server, Topic1, Topic2...)
    static std::wstring wProgID = L"GoldenProj.Rtd";
    
    int xlRet = xll::CallExcel(xlfRtd, &xRes, 
        wProgID.c_str(), 
        L"", 
        t0.c_str() 
        , t1.c_str(), t2.c_str(), t3.c_str()
    );

    if (xlRet != xlretSuccess) {
        SAFE_LOG_ERROR("xlfRtd failed for RtdScalars. Return code: " + std::to_string(xlRet));
        xRes.xltype = xltypeErr;
        xRes.val.err = xlerrValue;
    } else {
        std::string valStr = "Unknown";
        if (xRes.xltype & xltypeStr) valStr = WideToUtf8(PascalToWString(xRes.val.str));
        else if (xRes.xltype & xltypeNum) valStr = std::to_string(xRes.val.num);
        else if (xRes.xltype & xltypeBool) valStr = xRes.val.xbool ? "TRUE" : "FALSE";
        else if (xRes.xltype & xltypeErr) valStr = "Error:" + std::to_string(xRes.val.err);
        
        SAFE_LOG_DEBUG("xlfRtd called for RtdScalars. Result type: " + std::to_string(xRes.xltype) + ", Value: " + valStr);
    }

    return &xRes;

    
}

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall RtdComposite(LPXLOPER12 g, FP12* ng) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: RtdComposite");

    
    // RTD Wrapper Implementation
    static thread_local XLOPER12 xRes;

    // Convert arguments to strings for RTD Topics
    // Topic 0: Function Name
    std::wstring t0 = L"RtdComposite";

    
    std::wstring t1;
    {
        
        // Composite arg (grid/numgrid/range/any): content-hash payload path
        // (AGENTS.md §19.3). The topic carries only the content-hash token; the
        // serialized payload travels once per calc cycle over MSG_SETREFCACHE
        // and the Go dispatch resolves token -> payload from its RefCache.
        
        std::string tok1 = xll::ContentHashToken('g', g);
        
        {
            // Build a SetRefCacheRequest{ key=token, val=Any(payload) } and
            // ship it ONCE per cycle (SendRefCachePayloadOnce dedups on the
            // token) BEFORE xlfRtd so the server has the payload cached before
            // ConnectData fires the handler.
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(tok1);
            bool rcOk = true;
            
            auto rcInner = xll::ConvertGridArg(g, rcb, &rcOk);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Grid, rcInner.Union());
            
            if (!rcOk) {
                // Coerce of the reference failed (xlretUncalced etc.) — do NOT
                // ship a degenerate payload under this token; the Go dispatch
                // will miss and push an explicit error to the topic.
                SAFE_LOG_WARN("RTD RtdComposite: composite arg coerce failed; skipping payload ship for token " + tok1);
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                if (!xll::SendRefCachePayloadOnce(tok1, rcb.GetBufferPointer(), rcb.GetSize())) {
                    SAFE_LOG_WARN("RTD RtdComposite: failed to ship composite arg payload for token " + tok1);
                }
            }
        }
        t1 = StringToWString(tok1);
        
    }
    
    std::wstring t2;
    {
        
        // Composite arg (grid/numgrid/range/any): content-hash payload path
        // (AGENTS.md §19.3). The topic carries only the content-hash token; the
        // serialized payload travels once per calc cycle over MSG_SETREFCACHE
        // and the Go dispatch resolves token -> payload from its RefCache.
        
        std::string tok2 = xll::ContentHashTokenFP12(ng);
        
        {
            // Build a SetRefCacheRequest{ key=token, val=Any(payload) } and
            // ship it ONCE per cycle (SendRefCachePayloadOnce dedups on the
            // token) BEFORE xlfRtd so the server has the payload cached before
            // ConnectData fires the handler.
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(tok2);
            bool rcOk = true;
            
            auto rcInner = ConvertNumGrid(ng, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::NumGrid, rcInner.Union());
            
            if (!rcOk) {
                // Coerce of the reference failed (xlretUncalced etc.) — do NOT
                // ship a degenerate payload under this token; the Go dispatch
                // will miss and push an explicit error to the topic.
                SAFE_LOG_WARN("RTD RtdComposite: composite arg coerce failed; skipping payload ship for token " + tok2);
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                if (!xll::SendRefCachePayloadOnce(tok2, rcb.GetBufferPointer(), rcb.GetSize())) {
                    SAFE_LOG_WARN("RTD RtdComposite: failed to ship composite arg payload for token " + tok2);
                }
            }
        }
        t2 = StringToWString(tok2);
        
    }
    

    // Call Excel RTD(ProgID, Server, Topic1, Topic2...)
    static std::wstring wProgID = L"GoldenProj.Rtd";
    
    int xlRet = xll::CallExcel(xlfRtd, &xRes, 
        wProgID.c_str(), 
        L"", 
        t0.c_str() 
        , t1.c_str(), t2.c_str()
    );

    if (xlRet != xlretSuccess) {
        SAFE_LOG_ERROR("xlfRtd failed for RtdComposite. Return code: " + std::to_string(xlRet));
        xRes.xltype = xltypeErr;
        xRes.val.err = xlerrValue;
    } else {
        std::string valStr = "Unknown";
        if (xRes.xltype & xltypeStr) valStr = WideToUtf8(PascalToWString(xRes.val.str));
        else if (xRes.xltype & xltypeNum) valStr = std::to_string(xRes.val.num);
        else if (xRes.xltype & xltypeBool) valStr = xRes.val.xbool ? "TRUE" : "FALSE";
        else if (xRes.xltype & xltypeErr) valStr = "Error:" + std::to_string(xRes.val.err);
        
        SAFE_LOG_DEBUG("xlfRtd called for RtdComposite. Result type: " + std::to_string(xRes.xltype) + ", Value: " + valStr);
    }

    return &xRes;

    
}

