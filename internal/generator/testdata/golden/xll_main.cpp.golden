        else if (xRes.xltype & xltypeBool) valStr = xRes.val.xbool ? "TRUE" : "FALSE";
        else if (xRes.xltype & xltypeErr) valStr = "Error:" + std::to_string(xRes.val.err);
        
        SAFE_LOG_DEBUG("xlfRtd called for RtdRangeAny. Result type: " + std::to_string(xRes.xltype) + ", Value: " + valStr);
    }

    return &xRes;

    
}

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall OnceScalar(int32_t i, double f) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: OnceScalar");

    
    // rtd-once Wrapper Implementation.
    //
    // Builds the same topic strings as plain rtd (t0=function name, t1.. =
    // stringified scalar args). The lifecycle (AGENTS.md §19.3):
    //   1. Compute the key. If a completed result is already cached
    //      (RtdOnceResults), return it WITHOUT calling xlfRtd. The cell then
    //      holds no RTD reference, so Excel calls DisconnectData at end of
    //      calc and the topic is torn down (Go-side unsubscribe via the
    //      existing path).
    //   2. Otherwise call xlfRtd. Excel calls ConnectData(topicID, strings),
    //      which registers the topicID->key mapping and returns the
    //      #GETTING_DATA placeholder. The Go server runs the handler once and
    //      pushes the result; ProcessRtdUpdate caches it under the key and
    //      recalcs the cell, which re-enters this wrapper and hits the cache.

    // Topic 0: Function Name
    std::wstring t0 = L"OnceScalar";

    
    std::wstring t1;
    
    {
        
        t1 = std::to_wstring(i);
        
    }
    
    std::wstring t2;
    
    {
        
        // %.17g round-trip (NOT std::to_wstring's 6-digit %f): the topic string
        // also feeds the once-key (MakeRtdOnceKey), so a 6-digit truncation would
        // collide distinct inputs onto one memo entry. Go parses %.17g fine.
        t2 = FormatDoubleRoundTrip(f);
        
    }
    

    {
        std::vector<std::wstring> topics = { t0 , t1, t2 };
        std::wstring onceKey = xll::MakeRtdOnceKey(topics);

        // 1. Cache hit: return the completed value directly (no xlfRtd).
        
        VARIANT cached; VariantInit(&cached);
        if (xll::RtdOnceRegistry::Instance().TryGetResult(onceKey, &cached)) {
            LPXLOPER12 op = xll::RtdOnceResultToXLOPER12(cached);
            VariantClear(&cached);
            if (op) return op;
            return &g_xlErrValue;
        }
        VariantClear(&cached);
        
    }

    // 2. Cache miss: ship any composite-arg payloads (once per cycle) so the
    //    server has them cached BEFORE ConnectData fires the handler, then
    //    issue xlfRtd. ConnectData returns #GETTING_DATA for this rtd-once
    //    topic (it recognizes the function name and substitutes the placeholder
    //    for the plain-rtd "Connecting..." BSTR).
    
    {
        static thread_local XLOPER12 xRes;
        static std::wstring wProgID = L"GoldenProj.Rtd";

        int xlRet = xll::CallExcel(xlfRtd, &xRes,
            wProgID.c_str(),
            L"",
            t0.c_str()
            , t1.c_str(), t2.c_str()
        );

        if (xlRet != xlretSuccess) {
            SAFE_LOG_ERROR("xlfRtd failed for rtd-once OnceScalar. Return code: " + std::to_string(xlRet));
            
            return &g_xlErrValue;
            
        }
        
        // First paint on a cache miss: return the resolved loading placeholder,
        // NOT xlfRtd's raw synchronous result (xRes) — for a brand-new topic that
        // is #N/A, which is what the cell would otherwise flash before the result
        // push arrives. The xlfRtd call above already wired the RTD subscription,
        // so the eventual result push recalcs this cell; it then hits the
        // RtdOnceRegistry cache short-circuit above and returns the real value.
        // The placeholder is #GETTING_DATA by default (loading_placeholder:
        // "getting_data"/""), #N/A ("na"), or verbatim text (any other value).
        // The error sentinels are process-global (no xlbitDLLFree, mirror
        // g_xlErrValue); custom text uses NewExcelString (DLL-owned, reclaimed by
        // xlAutoFree12).
        (void)xRes;
        return &g_xlErrGettingData;
        
    }

    
}

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall OnceGrid(LPXLOPER12 s) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: OnceGrid");

    
    // rtd-once Wrapper Implementation.
    //
    // Builds the same topic strings as plain rtd (t0=function name, t1.. =
    // stringified scalar args). The lifecycle (AGENTS.md §19.3):
    //   1. Compute the key. If a completed result is already cached
    //      (RtdOnceResults), return it WITHOUT calling xlfRtd. The cell then
    //      holds no RTD reference, so Excel calls DisconnectData at end of
    //      calc and the topic is torn down (Go-side unsubscribe via the
    //      existing path).
    //   2. Otherwise call xlfRtd. Excel calls ConnectData(topicID, strings),
    //      which registers the topicID->key mapping and returns the
    //      #GETTING_DATA placeholder. The Go server runs the handler once and
    //      pushes the result; ProcessRtdUpdate caches it under the key and
    //      recalcs the cell, which re-enters this wrapper and hits the cache.

    // Topic 0: Function Name
    std::wstring t0 = L"OnceGrid";

    
    std::wstring t1;
    
    {
        
        if (s->xltype == xltypeStr) {
            t1 = PascalToWString(s->val.str);
        }
        
    }
    

    {
        std::vector<std::wstring> topics = { t0 , t1 };
        std::wstring onceKey = xll::MakeRtdOnceKey(topics);

        // 1. Cache hit: return the completed value directly (no xlfRtd).
        
        // grid-once cache hit: the host stored the WHOLE serialized
        // protocol::RtdOnceGridResult buffer under this key (Task 4). Recover
        // the grid from the Any union and spill it. The null-union guard mirrors
        // the SYNC grid path: a null pointer flows straight into the converter,
        // which yields the same error/empty result it produces for a null
        // resp->result() (GridToXLOPER12 -> #VALUE!, NumGridToFP12 -> 0x0).
        {
            std::vector<uint8_t> gbytes;
            if (xll::RtdOnceGridRegistry::Instance().TryGet(onceKey, &gbytes)) {
                auto* r = flatbuffers::GetRoot<protocol::RtdOnceGridResult>(gbytes.data());
                const protocol::Any* any = r ? r->value() : nullptr;
                
                const protocol::Grid* gr = any ? any->val_as_Grid() : nullptr;
                // grid-once spill: schedule date auto-format for any Date cells
                // before materializing. The Any wrapper carries the dates.
                xll::ScheduleDateFormatsForCaller(any);
                return GridToXLOPER12(gr);
                
            }
        }
        
    }

    // 2. Cache miss: ship any composite-arg payloads (once per cycle) so the
    //    server has them cached BEFORE ConnectData fires the handler, then
    //    issue xlfRtd. ConnectData returns #GETTING_DATA for this rtd-once
    //    topic (it recognizes the function name and substitutes the placeholder
    //    for the plain-rtd "Connecting..." BSTR).
    
    {
        static thread_local XLOPER12 xRes;
        static std::wstring wProgID = L"GoldenProj.Rtd";

        int xlRet = xll::CallExcel(xlfRtd, &xRes,
            wProgID.c_str(),
            L"",
            t0.c_str()
            , t1.c_str()
        );

        if (xlRet != xlretSuccess) {
            SAFE_LOG_ERROR("xlfRtd failed for rtd-once OnceGrid. Return code: " + std::to_string(xlRet));
            
            return &g_xlErrValue;
            
        }
        
        // First paint on a cache miss: return the resolved loading placeholder,
        // NOT xlfRtd's raw synchronous result (xRes) — for a brand-new topic that
        // is #N/A, which is what the cell would otherwise flash before the result
        // push arrives. The xlfRtd call above already wired the RTD subscription,
        // so the eventual result push recalcs this cell; it then hits the
        // RtdOnceRegistry cache short-circuit above and returns the real value.
        // The placeholder is #GETTING_DATA by default (loading_placeholder:
        // "getting_data"/""), #N/A ("na"), or verbatim text (any other value).
        // The error sentinels are process-global (no xlbitDLLFree, mirror
        // g_xlErrValue); custom text uses NewExcelString (DLL-owned, reclaimed by
        // xlAutoFree12).
        (void)xRes;
        return &g_xlErrGettingData;
        
    }

    
}

extern "C" __declspec(dllexport) FP12* __stdcall OnceNumGrid(LPXLOPER12 s) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // FP12* (K%) functions cannot return an XLOPER12 sentinel; a null
        // FP12* is the established error convention (NumGridToFP12's own
        // error paths return nullptr; Excel renders #NUM!). This covers BOTH
        // sync numgrid AND rtd-once numgrid — both export FP12* (K%), so the
        // &g_xlErrValue (LPXLOPER12) sentinel below would be a type mismatch.
        return nullptr;
        
    }

    SAFE_LOG_DEBUG("Func Entry: OnceNumGrid");

    
    // rtd-once Wrapper Implementation.
    //
    // Builds the same topic strings as plain rtd (t0=function name, t1.. =
    // stringified scalar args). The lifecycle (AGENTS.md §19.3):
    //   1. Compute the key. If a completed result is already cached
    //      (RtdOnceResults), return it WITHOUT calling xlfRtd. The cell then
    //      holds no RTD reference, so Excel calls DisconnectData at end of
    //      calc and the topic is torn down (Go-side unsubscribe via the
    //      existing path).
    //   2. Otherwise call xlfRtd. Excel calls ConnectData(topicID, strings),
    //      which registers the topicID->key mapping and returns the
    //      #GETTING_DATA placeholder. The Go server runs the handler once and
    //      pushes the result; ProcessRtdUpdate caches it under the key and
    //      recalcs the cell, which re-enters this wrapper and hits the cache.

    // Topic 0: Function Name
    std::wstring t0 = L"OnceNumGrid";

    
    std::wstring t1;
    
    {
        
        if (s->xltype == xltypeStr) {
            t1 = PascalToWString(s->val.str);
        }
        
    }
    

    {
        std::vector<std::wstring> topics = { t0 , t1 };
        std::wstring onceKey = xll::MakeRtdOnceKey(topics);

        // 1. Cache hit: return the completed value directly (no xlfRtd).
        
        // grid-once cache hit: the host stored the WHOLE serialized
        // protocol::RtdOnceGridResult buffer under this key (Task 4). Recover
        // the grid from the Any union and spill it. The null-union guard mirrors
        // the SYNC grid path: a null pointer flows straight into the converter,
        // which yields the same error/empty result it produces for a null
        // resp->result() (GridToXLOPER12 -> #VALUE!, NumGridToFP12 -> 0x0).
        {
            std::vector<uint8_t> gbytes;
            if (xll::RtdOnceGridRegistry::Instance().TryGet(onceKey, &gbytes)) {
                auto* r = flatbuffers::GetRoot<protocol::RtdOnceGridResult>(gbytes.data());
                const protocol::Any* any = r ? r->value() : nullptr;
                
                const protocol::NumGrid* ng = any ? any->val_as_NumGrid() : nullptr;
                return NumGridToFP12(ng);
                
            }
        }
        
    }

    // 2. Cache miss: ship any composite-arg payloads (once per cycle) so the
    //    server has them cached BEFORE ConnectData fires the handler, then
    //    issue xlfRtd. ConnectData returns #GETTING_DATA for this rtd-once
    //    topic (it recognizes the function name and substitutes the placeholder
    //    for the plain-rtd "Connecting..." BSTR).
    
    {
        static thread_local XLOPER12 xRes;
        static std::wstring wProgID = L"GoldenProj.Rtd";

        int xlRet = xll::CallExcel(xlfRtd, &xRes,
            wProgID.c_str(),
            L"",
            t0.c_str()
            , t1.c_str()
        );

        if (xlRet != xlretSuccess) {
            SAFE_LOG_ERROR("xlfRtd failed for rtd-once OnceNumGrid. Return code: " + std::to_string(xlRet));
            
            (void)xRes;
            return NumGridToFP12(nullptr);
            
        }
        
        // numgrid exports FP12* (K%), so it cannot carry a cell error and thus
        // cannot use the #GETTING_DATA sentinel the scalar/grid paths return on a
        // cache miss. Emit an empty 0x0 FP12 placeholder (NumGridToFP12(nullptr))
        // instead — the readiness push from RunOnceGrid recalcs the cell, which
        // then hits the grid registry above and spills the real numgrid.
        (void)xRes;
        return NumGridToFP12(nullptr);
        
    }

    
}

extern "C" __declspec(dllexport) LPXLOPER12 __stdcall OnceComposite(LPXLOPER12 g, FP12* ng, LPXLOPER12 r, LPXLOPER12 a) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: OnceComposite");

    
    // rtd-once Wrapper Implementation.
    //
    // Builds the same topic strings as plain rtd (t0=function name, t1.. =
    // stringified scalar args). The lifecycle (AGENTS.md §19.3):
    //   1. Compute the key. If a completed result is already cached
    //      (RtdOnceResults), return it WITHOUT calling xlfRtd. The cell then
    //      holds no RTD reference, so Excel calls DisconnectData at end of
    //      calc and the topic is torn down (Go-side unsubscribe via the
    //      existing path).
    //   2. Otherwise call xlfRtd. Excel calls ConnectData(topicID, strings),
    //      which registers the topicID->key mapping and returns the
    //      #GETTING_DATA placeholder. The Go server runs the handler once and
    //      pushes the result; ProcessRtdUpdate caches it under the key and
    //      recalcs the cell, which re-enters this wrapper and hits the cache.

    // Topic 0: Function Name
    std::wstring t0 = L"OnceComposite";

    
    std::wstring t1;
    
    // Composite-arg payloads, built now (for the content hash that goes into
    // the once-key) but SHIPPED only on a cache miss (just before xlfRtd).
    std::vector<uint8_t> refPayload1;
    std::string refTok1;
    
    {
        
        // Composite arg (grid/numgrid/range/any): content-hash payload path.
        // The token is content-addressed, so it flows into the once-key below
        // (MakeRtdOnceKey) and makes memoization content-addressed for free:
        // the same input grid hits the cache; an edited grid yields a new
        // token -> new key -> fresh compute (AGENTS.md §19.3).
        
        refTok1 = xll::ContentHashToken('g', g);
        
        {
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(refTok1);
            bool rcOk = true;
            
            auto rcInner = xll::ConvertGridArg(g, rcb, &rcOk);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Grid, rcInner.Union());
            
            if (!rcOk) {
                // Coerce failed: leave refPayload empty — the ship step below
                // skips empty payloads and the Go dispatch surfaces an explicit
                // miss error instead of a silent degenerate grid.
                SAFE_LOG_WARN("rtd-once OnceComposite: composite arg coerce failed; skipping payload for token " + refTok1);
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                refPayload1.assign(rcb.GetBufferPointer(), rcb.GetBufferPointer() + rcb.GetSize());
            }
        }
        t1 = StringToWString(refTok1);
        
    }
    
    std::wstring t2;
    
    // Composite-arg payloads, built now (for the content hash that goes into
    // the once-key) but SHIPPED only on a cache miss (just before xlfRtd).
    std::vector<uint8_t> refPayload2;
    std::string refTok2;
    
    {
        
        // Composite arg (grid/numgrid/range/any): content-hash payload path.
        // The token is content-addressed, so it flows into the once-key below
        // (MakeRtdOnceKey) and makes memoization content-addressed for free:
        // the same input grid hits the cache; an edited grid yields a new
        // token -> new key -> fresh compute (AGENTS.md §19.3).
        
        refTok2 = xll::ContentHashTokenFP12(ng);
        
        {
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(refTok2);
            bool rcOk = true;
            
            auto rcInner = ConvertNumGrid(ng, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::NumGrid, rcInner.Union());
            
            if (!rcOk) {
                // Coerce failed: leave refPayload empty — the ship step below
                // skips empty payloads and the Go dispatch surfaces an explicit
                // miss error instead of a silent degenerate grid.
                SAFE_LOG_WARN("rtd-once OnceComposite: composite arg coerce failed; skipping payload for token " + refTok2);
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                refPayload2.assign(rcb.GetBufferPointer(), rcb.GetBufferPointer() + rcb.GetSize());
            }
        }
        t2 = StringToWString(refTok2);
        
    }
    
    std::wstring t3;
    
    // Composite-arg payloads, built now (for the content hash that goes into
    // the once-key) but SHIPPED only on a cache miss (just before xlfRtd).
    std::vector<uint8_t> refPayload3;
    std::string refTok3;
    
    {
        
        // Composite arg (grid/numgrid/range/any): content-hash payload path.
        // The token is content-addressed, so it flows into the once-key below
        // (MakeRtdOnceKey) and makes memoization content-addressed for free:
        // the same input grid hits the cache; an edited grid yields a new
        // token -> new key -> fresh compute (AGENTS.md §19.3).
        
        refTok3 = xll::ContentHashToken('r', r);
        
        {
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(refTok3);
            bool rcOk = true;
            
            auto rcInner = ConvertRange(r, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Range, rcInner.Union());
            
            if (!rcOk) {
                // Coerce failed: leave refPayload empty — the ship step below
                // skips empty payloads and the Go dispatch surfaces an explicit
                // miss error instead of a silent degenerate grid.
                SAFE_LOG_WARN("rtd-once OnceComposite: composite arg coerce failed; skipping payload for token " + refTok3);
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                refPayload3.assign(rcb.GetBufferPointer(), rcb.GetBufferPointer() + rcb.GetSize());
            }
        }
        t3 = StringToWString(refTok3);
        
    }
    
    std::wstring t4;
    
    // Composite-arg payloads, built now (for the content hash that goes into
    // the once-key) but SHIPPED only on a cache miss (just before xlfRtd).
    std::vector<uint8_t> refPayload4;
    std::string refTok4;
    
    {
        
        // Composite arg (grid/numgrid/range/any): content-hash payload path.
        // The token is content-addressed, so it flows into the once-key below
        // (MakeRtdOnceKey) and makes memoization content-addressed for free:
        // the same input grid hits the cache; an edited grid yields a new
        // token -> new key -> fresh compute (AGENTS.md §19.3).
        
        refTok4 = xll::ContentHashToken('a', a);
        
        {
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(refTok4);
            bool rcOk = true;
            
            auto rcAny = ConvertAny(a, rcb);
            
            if (!rcOk) {
                // Coerce failed: leave refPayload empty — the ship step below
                // skips empty payloads and the Go dispatch surfaces an explicit
                // miss error instead of a silent degenerate grid.
                SAFE_LOG_WARN("rtd-once OnceComposite: composite arg coerce failed; skipping payload for token " + refTok4);
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                refPayload4.assign(rcb.GetBufferPointer(), rcb.GetBufferPointer() + rcb.GetSize());
            }
        }
        t4 = StringToWString(refTok4);
        
    }
    

    {
        std::vector<std::wstring> topics = { t0 , t1, t2, t3, t4 };
        std::wstring onceKey = xll::MakeRtdOnceKey(topics);

        // 1. Cache hit: return the completed value directly (no xlfRtd).
        
        VARIANT cached; VariantInit(&cached);
        if (xll::RtdOnceRegistry::Instance().TryGetResult(onceKey, &cached)) {
            LPXLOPER12 op = xll::RtdOnceResultToXLOPER12(cached);
            VariantClear(&cached);
            if (op) return op;
            return &g_xlErrValue;
        }
        VariantClear(&cached);
        
    }

    // 2. Cache miss: ship any composite-arg payloads (once per cycle) so the
    //    server has them cached BEFORE ConnectData fires the handler, then
    //    issue xlfRtd. ConnectData returns #GETTING_DATA for this rtd-once
    //    topic (it recognizes the function name and substitutes the placeholder
    //    for the plain-rtd "Connecting..." BSTR).
    
    if (!refPayload1.empty()) {
        if (!xll::SendRefCachePayloadOnce(refTok1, refPayload1.data(), refPayload1.size())) {
            SAFE_LOG_WARN("rtd-once OnceComposite: failed to ship composite arg payload for token " + refTok1);
        }
    }
    
    if (!refPayload2.empty()) {
        if (!xll::SendRefCachePayloadOnce(refTok2, refPayload2.data(), refPayload2.size())) {
            SAFE_LOG_WARN("rtd-once OnceComposite: failed to ship composite arg payload for token " + refTok2);
        }
    }
    
    if (!refPayload3.empty()) {
        if (!xll::SendRefCachePayloadOnce(refTok3, refPayload3.data(), refPayload3.size())) {
            SAFE_LOG_WARN("rtd-once OnceComposite: failed to ship composite arg payload for token " + refTok3);
        }
    }
    
    if (!refPayload4.empty()) {
        if (!xll::SendRefCachePayloadOnce(refTok4, refPayload4.data(), refPayload4.size())) {
