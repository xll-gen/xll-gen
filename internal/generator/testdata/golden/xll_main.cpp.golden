extern "C" __declspec(dllexport) LPXLOPER12 __stdcall OnceMemoize(int32_t i) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        
    }

    SAFE_LOG_DEBUG("Func Entry: OnceMemoize");

    
    // rtd-once Wrapper Implementation.
    //
    // Builds the same topic strings as plain rtd (t0=function name, t1.. =
    // stringified scalar args). The lifecycle (AGENTS.md §19.3):
    //   1. Compute the key. If a completed result is already cached
    //      (RtdOnceResults), return it WITHOUT calling xlfRtd. The cell then
    //      holds no RTD reference, so Excel calls DisconnectData at end of
    //      calc and the topic is torn down (Go-side unsubscribe via the
    //      existing path).
    //   2. Otherwise call xlfRtd. Excel calls ConnectData(topicID, strings),
    //      which registers the topicID->key mapping and returns the
    //      #GETTING_DATA placeholder. The Go server runs the handler once and
    //      pushes the result; ProcessRtdUpdate caches it under the key and
    //      recalcs the cell, which re-enters this wrapper and hits the cache.

    // Topic 0: Function Name
    std::wstring t0 = L"OnceMemoize";

    
    std::wstring t1;
    
    {
        
        t1 = std::to_wstring(i);
        
    }
    

    {
        std::vector<std::wstring> topics = { t0 , t1 };
        std::wstring onceKey = xll::MakeRtdOnceKey(topics);

        // 1. Cache hit: return the completed value directly (no xlfRtd).
        
        VARIANT cached; VariantInit(&cached);
        if (xll::RtdOnceRegistry::Instance().TryGetResult(onceKey, &cached)) {
            LPXLOPER12 op = xll::RtdOnceResultToXLOPER12(cached);
            VariantClear(&cached);
            if (op) return op;
            return &g_xlErrValue;
        }
        VariantClear(&cached);
        
    }

    // 2. Cache miss: ship any composite-arg payloads (once per cycle) so the
    //    server has them cached BEFORE ConnectData fires the handler, then
    //    issue xlfRtd. ConnectData returns #GETTING_DATA for this rtd-once
    //    topic (it recognizes the function name and substitutes the placeholder
    //    for the plain-rtd "Connecting..." BSTR).
    
    {
        static thread_local XLOPER12 xRes;
        static std::wstring wProgID = L"GoldenProj.Rtd";

        int xlRet = xll::CallExcel(xlfRtd, &xRes,
            wProgID.c_str(),
            L"",
            t0.c_str()
            , t1.c_str()
        );

        if (xlRet != xlretSuccess) {
            SAFE_LOG_ERROR("xlfRtd failed for rtd-once OnceMemoize. Return code: " + std::to_string(xlRet));
            
            return &g_xlErrValue;
            
        }
        
        // First paint on a cache miss: return the resolved loading placeholder,
        // NOT xlfRtd's raw synchronous result (xRes) — for a brand-new topic that
        // is #N/A, which is what the cell would otherwise flash before the result
        // push arrives. The xlfRtd call above already wired the RTD subscription,
        // so the eventual result push recalcs this cell; it then hits the
        // RtdOnceRegistry cache short-circuit above and returns the real value.
        // The placeholder is #GETTING_DATA by default (loading_placeholder:
        // "getting_data"/""), #N/A ("na"), or verbatim text (any other value).
        // The error sentinels are process-global (no xlbitDLLFree, mirror
        // g_xlErrValue); custom text uses NewExcelString (DLL-owned, reclaimed by
        // xlAutoFree12).
        (void)xRes;
        return &g_xlErrGettingData;
        
    }

    
}

