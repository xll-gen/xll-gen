    // placeholders (${BIN}, ${BIN_DIR}, ${XLL_DIR}) are expanded by
    // ResolveServerPath. Empty launches the server executable (${BIN}).
    cfg.command = "";
    cfg.shmName = shmName;
    cfg.tempDir = StringToWString(tempPattern);

    if (!LaunchServer(cfg, GetXllDir(), g_procInfo, launchLog)) {
            return 0;
    }

    // Start Monitor Thread
    g_monitorThread = std::thread(MonitorThread, launchLog);

start_worker:
    

    // Start Worker Thread for Async Results
    xll::StartWorker();

    // Register Events

    xll::CallExcel(xlEventRegister, nullptr, L"OnRecalc", xleventCalculationEnded);

    
    

    {
        // Register the calc-end DEFERRED COMMAND RUNNER macro (macroType=2).
        // HandleCalculationEnded schedules this via xlcOnTime so the
        // cell-mutating commands (xlSet) and date-format application
        // (COM Range.NumberFormat) run OUTSIDE the xleventCalculationEnded
