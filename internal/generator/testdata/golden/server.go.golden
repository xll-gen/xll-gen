func handleSyncStr(ctx context.Context, req []byte, respBuf []byte, handler XllService, b *flatbuffers.Builder, client *shm.Client, msgType shm.MsgType, refCache *server.RefCache) (int32, shm.MsgType) {
	request := ipc.GetRootAsSyncStrRequest(req, 0)
	_ = request

	
	
	arg_s := string(request.S())
	
	

	

	
	var res string
	var err error

	log.Debug("Sync function start", "func", "SyncStr")

	func() {
		defer func() {
			if r := recover(); r != nil {
				stack := debug.Stack()
				log.Error("Panic in sync handler SyncStr", "error", r, "stack", string(stack))
				err = fmt.Errorf("panic: %v", r)
			}
			log.Debug("Sync function end", "func", "SyncStr")
		}()
		res, err = handler.SyncStr(ctx, arg_s)
	}()

	b.Reset()
	var errOffset flatbuffers.UOffsetT
	if err != nil {
		errOffset = b.CreateString(err.Error())
	}

	
	var resOffset flatbuffers.UOffsetT
	if err == nil {
		resOffset = b.CreateString(res)
	}
	

	ipc.SyncStrResponseStart(b)
	if err != nil {
		ipc.SyncStrResponseAddError(b, errOffset)
	} else {
		
		if resOffset > 0 {
			ipc.SyncStrResponseAddResult(b, resOffset)
		}
		
	}
	root := ipc.SyncStrResponseEnd(b)
