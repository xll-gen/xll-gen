	_ = request

	
	
	var arg_a *protocol.Any
	arg_a_raw := request.A(nil)
	if arg_a_raw != nil {
		if arg_a_raw.ValType() == protocol.AnyValueRefCache {
			var rc protocol.RefCache
			init := new(flatbuffers.Table)
			if arg_a_raw.Val(init) {
				rc.Init(init.Bytes, init.Pos)
				key := string(rc.Key())
				if data, ok := refCache.Get(key); ok {
					cacheReq := protocol.GetRootAsSetRefCacheRequest(data, 0)
					arg_a = cacheReq.Val(nil)
				} else {
					arg_a = arg_a_raw
				}
			}
		} else {
			arg_a = arg_a_raw
		}
	}
	
	

	

	
	handle := request.AsyncHandleBytes()

	log.Debug("Async function start", "func", "AsyncAny")

	if ctx.Err() != nil {
		asyncBatcher.QueueResult(handle, nil, protocol.AnyValue(0), ctx.Err().Error())
		return 0, 0
	}

	func() {
		defer func() {
			if r := recover(); r != nil {
				stack := debug.Stack()
				log.Error("Panic in async handler AsyncAny", "error", r, "stack", string(stack))
				asyncBatcher.QueueResult(handle, nil, protocol.AnyValue(0), fmt.Sprintf("panic: %v", r))
			}
			log.Debug("Async function end", "func", "AsyncAny")
		}()

		log.Debug("Processing async request", "func", "AsyncAny")

		res, err := handler.AsyncAny(ctx, arg_a)

		if err != nil {
			asyncBatcher.QueueResult(handle, nil, protocol.AnyValue(0), err.Error())
		} else {
			
			tag, payload := server.MapAnyValue(res)
			asyncBatcher.QueueResult(handle, payload, tag, "")
			
		}
	}()

	return 0, 0
	
}




















