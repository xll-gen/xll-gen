{{if .Ribbon.Enabled}}
// Returns the hosting Excel's Application IDispatch (AddRef'd; caller releases),
// performing a synchronous temporary-workbook "bounce" when it is not directly
// reachable. This is the no-workbook-at-load fix: when the add-in auto-loads at
// Excel startup with NO document open, there is no EXCEL7 child window, so
// GetExcelApplication() returns nullptr and the COMAddIns connect cannot run.
//
// Mechanism adopted from Excel-DNA (Source/ExcelDna.Integration/Excel.cs,
// GetApplicationFromNewWorkbook): create a temp workbook via the XLM command
// API, which materializes the EXCEL7 window, grab the Application, then close
// the temp workbook with no save. The COMAddIns connect binds to the
// Application (not the workbook), so it survives the temp workbook closing —
// the ribbon tab appears normally when the user later opens a workbook. Cost is
// a brief startup flicker when Excel starts empty (accepted).
//
// XLM command opcodes (xlc*) are callable ONLY from a macro/command context;
// xlAutoOpen qualifies. Do NOT call this from worksheet-function or RTD
// contexts. Graceful degradation: if the bounce fails (C API unavailable,
// command rejected), log a warning and return nullptr — never crash.
// Returns the name of the currently ACTIVE workbook via the XLM macro function
// GET.DOCUMENT(88) (xlfGetDocument, selector 88 = "name of the active document/
// workbook", e.g. L"Book1"), or an empty string if it cannot be determined.
// Selector 88 verified in types/include/types/xlcall.h (#define xlfGetDocument 188)
// against the XLM GET.DOCUMENT reference (type_num 88 -> active workbook name).
// The result is an Excel-allocated Pascal string, so it is held in a
// ScopedXLOPER12Result (xlFree on destruction) and decoded with PascalToWString —
// the same idiom used for the macro caller number-format path in this template.
static std::wstring GetActiveWorkbookName() {
    ScopedXLOPER12Result xName;
    if (xll::CallExcel(xlfGetDocument, xName, 88) != xlretSuccess) return std::wstring();
    if ((xName.get()->xltype & xltypeStr) == 0 || !xName.get()->val.str) return std::wstring();
    return PascalToWString(xName.get()->val.str);
}

static IDispatch* GetExcelApplicationOrBounce() {
    IDispatch* pApp = GetExcelApplication();
    if (pApp) return pApp; // workbook already exists -> no bounce needed

    // No EXCEL7 window yet. Create a temp workbook so one exists, then close it.
    //   xlcNew(5)            -> new workbook
    //   xlcWorkbookInsert(6) -> insert a worksheet so it is a real workbook
    // (verified opcode names in types/include/types/xlcall.h).
    int rcNew = xll::CallExcel(xlcNew, nullptr, 5);
    if (rcNew != xlretSuccess) {
        SAFE_LOG_WARN("Ribbon: temp-workbook bounce failed (xlcNew rc=" + std::to_string(rcNew) + "); connect deferred to calc-end fallback.");
        return nullptr;
    }
    // xlcWorkbookInsert is best-effort; xlcNew(5) already yields a workbook with
    // a sheet. Don't fail the bounce if the insert is rejected.
    xll::CallExcel(xlcWorkbookInsert, nullptr, 6);

    // The scratch book is ACTIVE right after creation: capture its name now so we
    // can close it by IDENTITY later. xlcFileClose(false) closes whatever is
    // active and DISCARDS unsaved changes; if a real user document became active
    // between create and close (Excel started as `excel.exe somedoc.xlsx` with
    // ordering not contractual), an unconditional close would silently lose the
    // user's work. Capturing the name lets us refuse the close in that case.
    std::wstring scratchName = GetActiveWorkbookName();

    // The EXCEL7 window now exists; re-acquire the Application.
    pApp = GetExcelApplication();

    // Close-by-identity: only close if the scratch book is STILL the active one.
    // Leaking a blank scratch book is strictly safer than discarding a user
    // document, so any uncertainty (empty captured name, name changed, name
    // re-read failed) leaves the book open.
    if (scratchName.empty()) {
        SAFE_LOG_WARN("Ribbon: temp-workbook bounce could not capture the scratch workbook name; leaving it open rather than risk discarding a user document.");
    } else {
        std::wstring activeNow = GetActiveWorkbookName();
        if (activeNow.empty() || activeNow != scratchName) {
            SAFE_LOG_WARN("Ribbon: temp-workbook bounce scratch workbook is no longer active (a user document may have become active); leaving the scratch workbook open to avoid discarding unsaved changes.");
        } else {
            // Identity confirmed: close the scratch book WITHOUT saving.
            // xlcFileClose(false) = close, discard changes.
            int rcClose = xll::CallExcel(xlcFileClose, nullptr, false);
            if (rcClose != xlretSuccess) {
                SAFE_LOG_WARN("Ribbon: temp-workbook bounce could not close the scratch workbook (xlcFileClose rc=" + std::to_string(rcClose) + ").");
            }
        }
    }

    if (!pApp) {
        SAFE_LOG_WARN("Ribbon: temp-workbook bounce did not yield an Application object; connect deferred to calc-end fallback.");
    }
    return pApp;
}
{{end}}

{{if and .Rtd.Enabled .Rtd.ThrottleInterval}}
// Applies rtd.throttle_interval from xll.yaml: Application.RTD.ThrottleInterval
// = <ms>. NOTE: this is a per-user, registry-persisted Excel setting — it is
// only touched because the config explicitly opted in.
static bool SetRtdThrottleInterval(long ms) {
    IDispatch* pApp = GetExcelApplication();
    if (!pApp) return false;

    bool ok = false;
    VARIANT vRtd; VariantInit(&vRtd);
    if (SUCCEEDED(xll::com::GetProperty(pApp, L"RTD", &vRtd)) && vRtd.vt == VT_DISPATCH && vRtd.pdispVal) {
        VARIANT vMs; VariantInit(&vMs);
        vMs.vt = VT_I4;
        vMs.lVal = ms;
        ok = SUCCEEDED(xll::com::Invoke(vRtd.pdispVal, L"ThrottleInterval", DISPATCH_PROPERTYPUT, { vMs }, nullptr));
    }
    VariantClear(&vRtd);
    pApp->Release();
    return ok;
}

// One-shot apply with bounded retries. At xlAutoOpen the native object model
// is often not reachable yet (no workbook -> no EXCEL7 child window: early
// startup loads AND automation hosts hit this), so the calc-end callbacks —
// which run on the main STA thread once a workbook exists — retry until it
// sticks. Bounded so a pathological host doesn't pay the window walk forever.
static std::atomic<int> g_rtdThrottleState{0}; // 0=pending, 1=applied, 2=gave up
static void TryApplyRtdThrottle(const char* phase) {
    if (g_rtdThrottleState.load(std::memory_order_acquire) != 0) return;
    static std::atomic<int> s_attempts{0};
    if (SetRtdThrottleInterval({{parseTimeout .Rtd.ThrottleInterval 2000}})) {
        g_rtdThrottleState.store(1, std::memory_order_release);
        SAFE_LOG_INFO(std::string("RTD: ThrottleInterval set to {{parseTimeout .Rtd.ThrottleInterval 2000}}ms (") + phase + ").");
    } else if (s_attempts.fetch_add(1) + 1 >= 10) {
        g_rtdThrottleState.store(2, std::memory_order_release);
        SAFE_LOG_WARN("RTD: could not set ThrottleInterval (Application object unreachable after 10 attempts); keeping the current Excel setting.");
    }
}
{{end}}

{{if .Ribbon.Enabled}}
// Sets Application.COMAddIns.Item(progId).Connect = <connected>. Used both
// to connect at xlAutoOpen and — critically — to DISCONNECT at xlAutoClose:
// revoking the class object does not release the live add-in instance Excel
// holds; without an explicit Connect=false Excel can keep a vtable pointer
// into this DLL past FreeLibrary and crash on quit (Excel-DNA does the same
// explicit disconnect for its helper add-in).
//
// pNoApp (optional, out): set to true when the failure is solely because the
// in-process Application object is not reachable yet (no workbook window -> no
// EXCEL7 child). Callers use this to avoid burning the give-up budget on the
// no-workbook-yet case (the user may open a workbook minutes later).
//
// allowBounce: when true, acquire the Application via GetExcelApplicationOrBounce
// (synchronous temp-workbook bounce when no workbook is open). Only the
// xlAutoOpen first-attempt path passes true; calc-end retries must not bounce
// (a workbook already exists there) and pass false.
static bool SetRibbonConnected(bool connected, bool* pNoApp, bool allowBounce) {
    if (pNoApp) *pNoApp = false;
    IDispatch* pApp = allowBounce ? GetExcelApplicationOrBounce() : GetExcelApplication();
    if (!pApp) {
        if (pNoApp) *pNoApp = true;
        return false;
    }

    bool ok = false;
    {
        VARIANT vAddins; VariantInit(&vAddins);
        if (SUCCEEDED(xll::com::GetProperty(pApp, L"COMAddIns", &vAddins)) && vAddins.vt == VT_DISPATCH && vAddins.pdispVal) {
            VARIANT vProg; VariantInit(&vProg);
            vProg.vt = VT_BSTR;
            vProg.bstrVal = SysAllocString(g_szRibbonProgID);
            VARIANT vItem; VariantInit(&vItem);
            if (SUCCEEDED(xll::com::Invoke(vAddins.pdispVal, L"Item", DISPATCH_METHOD | DISPATCH_PROPERTYGET, { vProg }, &vItem))
                && vItem.vt == VT_DISPATCH && vItem.pdispVal) {
                VARIANT vConn; VariantInit(&vConn);
                vConn.vt = VT_BOOL;
                vConn.boolVal = connected ? VARIANT_TRUE : VARIANT_FALSE;
                ok = SUCCEEDED(xll::com::Invoke(vItem.pdispVal, L"Connect", DISPATCH_PROPERTYPUT, { vConn }, nullptr));
            }
            VariantClear(&vItem);
            VariantClear(&vProg);  // frees the BSTR (caller owns args per dispatch_helpers contract)
        }
        VariantClear(&vAddins);
    }
    pApp->Release();
    return ok;
}

// Ribbon COM add-in bootstrap, made idempotent + retryable. The COMAddIns
// connect (step 4) needs the in-process Application object, which is reachable
// only through the XLDESK -> EXCEL7 child window. When the XLL loads with NO
// workbook open (add-in auto-loaded at Excel startup), that child window does
// not exist yet, so GetExcelApplication() returns nullptr.
//
// Primary mechanism: the xlAutoOpen first attempt passes allowBounce=true, so
// SetRibbonConnected -> GetExcelApplicationOrBounce synchronously materializes
// a workbook (Excel-DNA's temp-workbook bounce) and the connect succeeds even
// with no document open. This replaces the former STA WM_TIMER retry loop,
// which was an accepted crash residual on forced unload (AGENTS.md §20.2).
//
// Defensive fallback: the calc-end callback retries TryConnectRibbon WITHOUT
// bouncing (allowBounce=false). It is an Excel-registered event callback (no
// idle-timer unmap hazard) and only matters in the rare case the bounce itself
// fails (e.g. C API unavailable). It is harmless and idempotent.
//
// State is a single atomic: 0=pending, 1=connected, 2=gave up after bounded
// attempts. Registry/class-object steps (1-3) are themselves idempotent, but
// we only redo the cheap, workbook-dependent connect (step 4) on retry once
// the one-time registration has succeeded.
static std::atomic<int> g_ribbonConnectState{0}; // 0=pending, 1=connected, 2=gave up
static std::atomic<bool> g_ribbonRegistered{false};

static bool TryConnectRibbon(const char* phase, bool allowBounce = false) {
    if (g_ribbonConnectState.load(std::memory_order_acquire) != 0) return true;
    if (g_isUnloading.load(std::memory_order_acquire)) return false;

    // Re-entrancy guard. The temp-workbook bounce (xlcNew/xlcWorkbookInsert) and
    // the COMAddIns Connect both pump the STA message loop, so an Excel callback
    // (e.g. CalculationEnded -> TryConnectRibbon("calc end")) can re-enter this
    // function on the SAME thread while a connect is mid-flight — reaching a
    // second concurrent COMAddIns…Connect. Single STA thread, so this is
    // re-entrancy, not a data race; bail out (still "pending") if already inside.
    static std::atomic<bool> s_inConnect{false};
    bool expected = false;
    if (!s_inConnect.compare_exchange_strong(expected, true)) return false;
    struct ConnectGuard {
        std::atomic<bool>& flag;
        ~ConnectGuard() { flag.store(false, std::memory_order_release); }
    } connectGuard{s_inConnect};

    // One-time, workbook-independent registration (steps 1-3). Done once;
    // guarded so retries skip straight to the connect.
    if (!g_ribbonRegistered.load(std::memory_order_acquire)) {
        xll::ribbon::SetRibbonXml(kXllRibbonXml);
        xll::ribbon::SetRibbonImages(GetXllRibbonImages());

        // 1. HKCU COM registration (CLSID/InprocServer32 + ProgID).
        if (FAILED(rtd::RegisterServer(g_hModule, GetRibbonClsid(), g_szRibbonProgID, L"{{.ProjectName}} Ribbon"))) {
            SAFE_LOG_WARN("Ribbon: HKCU COM registration failed (locked-down registry?); ribbon UI disabled.");
            g_ribbonConnectState.store(2, std::memory_order_release);
            return false;
        }
        // 2. Office Addins key so COMAddIns enumerates us.
        if (FAILED(rtd::RegisterOfficeAddinKey(g_szRibbonProgID, L"{{.ProjectName}}", L"{{.ProjectName}} ribbon helper"))) {
            SAFE_LOG_WARN("Ribbon: Office Addins key registration failed; ribbon UI disabled.");
            g_ribbonConnectState.store(2, std::memory_order_release);
            return false;
        }
        // 3. In-memory class object so CoCreateInstance resolves without a
        //    registry CLSID lookup (mirrors the RTD pattern).
        rtd::ClassFactory<RibbonAddIn>* pFactory = new rtd::ClassFactory<RibbonAddIn>();
        HRESULT hr = CoRegisterClassObject(GetRibbonClsid(), pFactory, CLSCTX_INPROC_SERVER, REGCLS_MULTIPLEUSE, &g_ribbonCookie);
        pFactory->Release();
        if (FAILED(hr)) {
            char hrBuf[16];
            snprintf(hrBuf, sizeof(hrBuf), "0x%08lX", static_cast<unsigned long>(hr));
            SAFE_LOG_WARN(std::string("Ribbon: CoRegisterClassObject failed: ") + hrBuf);
            g_ribbonConnectState.store(2, std::memory_order_release);
            return false;
        }
        g_ribbonRegistered.store(true, std::memory_order_release);
    }

    // 4. Connect through Application.COMAddIns (synchronous; Excel calls
    //    GetCustomUI during this call). Needs the EXCEL7 window. When
    //    allowBounce is true (xlAutoOpen path) the temp-workbook bounce inside
    //    GetExcelApplicationOrBounce materializes that window when no document
    //    is open, so this normally succeeds on the very first attempt.
    bool noApp = false;
    if (SetRibbonConnected(true, &noApp, allowBounce)) {
        g_ribbonConnectState.store(1, std::memory_order_release);
        SAFE_LOG_INFO(std::string("Ribbon: COM add-in connected (") + phase + ").");
        return true;
    }

    // Still no Application object (only reachable if the bounce failed, or on a
    // calc-end retry before a workbook exists): the user simply hasn't opened a
    // workbook. Do NOT consume the give-up budget — the defensive calc-end
    // fallback retries until a workbook appears.
    if (noApp) return false;

    // Real connect failure (Application reachable but Connect rejected): bound
    // it so a pathological host doesn't retry forever.
    static std::atomic<int> s_attempts{0};
    if (s_attempts.fetch_add(1) + 1 >= 60) {
        g_ribbonConnectState.store(2, std::memory_order_release);
        SAFE_LOG_WARN("Ribbon: COMAddIns connect failed after 60 attempts; ribbon UI disabled.");
    }
    return false;
}
{{end}}

// XLL Interface Functions

extern "C" __declspec(dllexport) int __stdcall xlAutoOpen() {
    XLL_SAFE_BLOCK_BEGIN
        ScopedXLOPER12Result xDLL; // Defined here for xlGetName

        // Setup Native Logging
        std::string tempPattern = "";
    std::string projName = "{{.ProjectName}}";
    bool isSingleFile = false;
    std::wstring launchLog;
    LaunchConfig cfg;

    {{if eq .Build.Singlefile "xll"}}
    isSingleFile = true;
    tempPattern = "{{.Build.TempDir}}";
    {{end}}

    std::wstring binDir = GetXllDir();
    {{if eq .Build.Singlefile "xll"}}
    binDir = ExpandEnvVarsW(L"{{.Build.TempDir}}");
    {{end}}

    std::wstring logPath = L"{{.Logging.Dir}}";
    if (logPath == L"XLL_DIR") {
        logPath = GetXllDir() + L"\\{{.ProjectName}}_native.log";
    } else if (logPath == L"TEMP_DIR") {
        logPath = ExpandEnvVarsW(L"${TEMP}") + L"\\{{.ProjectName}}_native.log";
    } else {
        // Support placeholders like ${XLL_DIR}, ${BIN_DIR} and ${TEMP}
        ReplaceAll(logPath, L"${XLL_DIR}", GetXllDir());
        ReplaceAll(logPath, L"${BIN_DIR}", binDir);
        logPath = ExpandEnvVarsW(logPath);

        // If it's a directory (or ends with slash), append default log name
        if (!logPath.empty() && (std::filesystem::is_directory(logPath) || logPath.back() == L'\\' || logPath.back() == L'/')) {
            if (logPath.back() != L'\\' && logPath.back() != L'/') logPath += L"\\";
            logPath += L"{{.ProjectName}}_native.log";
        }
    }

    std::string logInitError;
    if (!InitLog(logPath, "{{.Logging.Level}}", tempPattern, projName, isSingleFile, logInitError)) {
            // If logging fails to initialize, we show a message box but proceed.
            // Logging is critical for debugging but not for core functionality.
            MessageBoxA(NULL, ("Failed to initialize logging: " + logInitError).c_str(), "XLL Initialization Warning", MB_OK | MB_ICONWARNING);
    } else {
            SAFE_LOG_INFO("Logging Initialized Successfully. LogPath: " + WideToUtf8(logPath));
    }

#ifdef SHM_DEBUG
    shm::SetLogHandler(LogHandler);
#endif

    SAFE_LOG_INFO("xlAutoOpen: Loading XLL...");

    xll::CallExcel(xlGetName, xDLL);

    {{if or .Ribbon.Enabled .Commands .Rtd.Enabled}}
    // Register the COM/ribbon/RTD destructive-teardown hook so that
    // xll::GracefulTeardownOnce() — driven by the CONFIRMED-shutdown COM events
    // (OnBeginShutdown / OnDisconnection), never by a cancelled quit — runs the
    // ribbon disconnect / class-object revoke / registry unregister exactly once.
    xll::SetGracefulTeardownHook(&GracefulComTeardownHook);
    {{end}}

    {{if .Rtd.Enabled}}
    // Register RTD Server in Registry
    DllRegisterServer();

    // Also register in memory for immediate access in this process
    rtd::ClassFactory<RtdServer>* pFactory = new rtd::ClassFactory<RtdServer>();
    HRESULT hr_reg = CoRegisterClassObject(GetRtdClsid(), pFactory, CLSCTX_INPROC_SERVER, REGCLS_MULTIPLEUSE, &g_rtdCookie);
    pFactory->Release();

    if (FAILED(hr_reg)) {
        SAFE_LOG_ERROR("CoRegisterClassObject failed: " + std::to_string(hr_reg));
    } else {
        SAFE_LOG_INFO("RTD Server registered in memory successfully.");
    }

    // Create the hidden HWND_MESSAGE window that routes RTD UpdateNotify onto this
    // STA (IMPROVEMENT_BACKLOG §0). MUST be created here, on the STA, BEFORE
    // xll::StartWorker() below — the worker's ProcessRtdUpdate calls
    // xll::SignalRtdUpdate(), which PostMessages to this window, so the window must
    // exist before any RTD update can arrive. Destroyed on the STA in
    // RunDestructiveTeardown (after JoinWorker). See xll_rtd_notify.{h,cpp}.
    xll::CreateRtdNotifyWindow();
    {{end}}

    // Initialize Shared Memory
    std::string shmName = "{{.ProjectName}}";
    {{if not .ShouldAppendPid}}
    // Static name for testing/dev
    {{else}}
    shmName += "_" + std::to_string(GetCurrentProcessId());
    {{end}}

    SAFE_LOG_INFO("Initializing Shared Memory: " + shmName);

    // HostConfig: hostSlots, guestSlots.
    shm::HostConfig hostCfg{};
    int workers = {{if .Server.Workers}}{{.Server.Workers}}{{else}}std::thread::hardware_concurrency(){{end}};
    if (workers < 1) workers = 1;
    hostCfg.numHostSlots = workers * 2 + 2;
    // Guest slots back every guest->host push: streaming RTD updates, one-shot
    // rtd-once results, and grid sends. A connect storm (many RTD topics
    // connecting at once on workbook open) plus a grid send that holds a slot
    // for the duration of its transfer can momentarily saturate this pool. With
    // shm >= v0.7.8 a push waits (up to its timeout) for a free slot instead of
    // failing, but a larger pool keeps that wait short and avoids stranding a
    // one-shot rtd-once cell at #GETTING_DATA under load.
    hostCfg.numGuestSlots = 4;
    hostCfg.shmName = shmName;
    hostCfg.payloadSize = 1024 * 1024; // 1MB

    // Initialize Host (Allocated if null to persist across Probe Unloads)
    if (!g_phost) {
        g_phost = new shm::DirectHost();
    }

    auto initRes = g_host.Init(hostCfg);
    if (initRes.HasError()) {
            std::string err = "Failed to initialize shared memory: " + SHMErrorToString(initRes.GetError());
            SAFE_LOG_ERROR(err);
            MessageBoxA(NULL, err.c_str(), "XLL Error", MB_OK | MB_ICONERROR);
            return 0; // Fail loading
    }

    // Launch Server Process
    {{if derefBool .Server.Launch.Enabled}}
    // Check if already running
    if (g_procInfo.hProcess != NULL) {
        DWORD exitCode = 0;
            if (GetExitCodeProcess(g_procInfo.hProcess, &exitCode) && exitCode == STILL_ACTIVE) {
                SAFE_LOG_INFO("Server process is already running. Skipping launch.");
        } else {
             // Process is dead, clean up handles
             if (g_procInfo.hProcess) CloseHandle(g_procInfo.hProcess);
             if (g_procInfo.hJob) CloseHandle(g_procInfo.hJob);
             if (g_procInfo.hShutdownEvent) CloseHandle(g_procInfo.hShutdownEvent);
             g_procInfo = { 0 };
             goto launch_server;
        }
    } else {
        goto launch_server;
    }
    // Skip launch if running
    goto start_worker;

launch_server:
    // Prepare Launch Config
    cfg.projectName = L"{{.ProjectName}}";
    cfg.isSingleFile = isSingleFile;
    cfg.cwd = ""; // Default CWD (relative to bindir)
    cfg.command = "{{.Server.Command}}";
    cfg.shmName = shmName;
    {{if eq .Build.Singlefile "xll"}}cfg.tempDir = StringToWString(tempPattern);{{end}}

    if (!LaunchServer(cfg, GetXllDir(), g_procInfo, launchLog)) {
            return 0;
    }

    // Start Monitor Thread
    g_monitorThread = std::thread(MonitorThread, launchLog);

start_worker:
    {{else}}
    SAFE_LOG_INFO("Server launch disabled by configuration.");
    {{end}}

    // Start Worker Thread for Async Results
    xll::StartWorker();

    // Register Events
{{range .Events}}
    xll::CallExcel(xlEventRegister, nullptr, L"{{.Handler}}", {{lookupEventCode .Type}});
{{end}}
    {{if hasEvent "CalculationEnded" .Events}}
    {{else}}
    // Date auto-format (Plan B / Task 4): ANY function may return a date, and
    // the date-format drain runs in HandleCalculationEnded. So CalculationEnded
    // must be registered unconditionally in every build — not just when an
    // `any` arg, cache, or ribbon needs it. The drain is cheap when nothing is
    // pending (a mutex-guarded empty-vector swap), so an always-on registration
    // costs nothing on date-free recalcs.
    bool needCalcEnded = true;
    bool hasCache = {{.Cache.Enabled}};
    {{range .Functions}}
    {{if .Cache}}
    {{if .Cache.Enabled}}
    hasCache = true;
    {{end}}
    {{end}}
    {{end}}

    {{range $i, $fn := .Functions}}{{range .Args}}{{if eq .Type "any"}}needCalcEnded=true;{{end}}{{end}}{{end}}
    {{if .Ribbon.Enabled}}
    // Ribbon keeps the calc-end callback as a DEFENSIVE FALLBACK retry hook for
    // the COMAddIns connect (see TryConnectRibbon). The xlAutoOpen temp-workbook
    // bounce normally connects on the first attempt even with no workbook open;
    // this hook only matters if that bounce fails. Unlike the removed STA timer
    // it is an Excel-registered event callback, so it has no unmap hazard.
    needCalcEnded = true; // needRibbonRetry: register CalculationEnded for the connect retry fallback
    {{end}}
    if (needCalcEnded || hasCache) {
            xll::CallExcel(xlEventRegister, nullptr, L"CalculationEnded", xleventCalculationEnded);
    }
    {{end}}

    {
        // Register the calc-end DEFERRED COMMAND RUNNER macro (macroType=2).
        // HandleCalculationEnded schedules this via xlcOnTime so the
        // cell-mutating commands (xlSet) and date-format application
        // (COM Range.NumberFormat) run OUTSIDE the xleventCalculationEnded
        // callback — fixing the rtd-once-window reentrancy crash (0xc0000005).
        // Registered unconditionally because CalculationEnded itself is (the
        // date-format drain is always-on). Idempotent: re-registering the same
        // procedure name is harmless. The macro is auto-unregistered when the
        // DLL unloads, so no explicit teardown is needed (§20.2). See
        // include/xll_deferred_commands.h.
        ScopedXLOPER12Result xRegId;
        int regRes = xll::RegisterFunction(
            *xDLL,
            xll::DeferredRunnerMacroName(), // Procedure (exported symbol below)
            L"I",                           // TypeText: "I" = 2-byte signed int (matches the short return below; macroType=2 ignores the value). See §19.2.
            xll::DeferredRunnerMacroName(), // FunctionText (hidden; xlcOnTime targets it)
            L"",                            // ArgumentText: none
            2,                              // macroType=2 (registered macro; xlcOnTime-callable)
            L"",                            // Category (unused)
            L"",                            // Shortcut (none)
            L"",                            // HelpTopic
            L"",                            // FunctionHelp
            {},                             // ArgumentHelp
            *xRegId
        );
        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register deferred calc-end runner macro. Code: " + std::to_string(regRes));
        }
    }

    {{if .Commands}}
    // Command names must be set before any command proc or ribbon callback
    // can run (set-before-connect contract, see com/ribbon_addin.h). This must
    // precede the xlfRegister loop below: once Cmd_<Name> is registered, a
    // Ctrl+Shift shortcut can fire the proc immediately and the proc looks the
    // name up in this table.
    xll::ribbon::SetCommands({ {{range .Commands}}L"{{.Name}}", {{end}} });
    {{end}}

    {{if anyRtdOnce .Functions}}
    // rtd-once: register the set of one-shot function names (the memoize
    // subset, and the memoize_ttl subset as name->ttl-ms pairs) BEFORE any
    // topic can connect, so ConnectData can recognize rtd-once topics and
    // return the #GETTING_DATA placeholder, and so CalculationEnded/read-time
    // expiry know which results to clear or age out.
    xll::RtdOnceRegistry::Instance().SetFunctionNames(
        { {{range .Functions}}{{if and (eq .Mode "rtd-once") (and (ne .Return "grid") (ne .Return "numgrid"))}}L"{{.Name}}", {{end}}{{end}} },
        { {{range .Functions}}{{if and (eq .Mode "rtd-once") (and (ne .Return "grid") (and (ne .Return "numgrid") .Memoize))}}L"{{.Name}}", {{end}}{{end}} },
        { {{range .Functions}}{{if and (eq .Mode "rtd-once") (and (ne .Return "grid") (and (ne .Return "numgrid") .MemoizeTTL))}}{ L"{{.Name}}", {{durationMillis .MemoizeTTL}}ULL }, {{end}}{{end}} }
    );
    {{end}}

    {{if anyRtdOnceGrid .Functions}}
    // grid-once: the byte-buffer twin of the scalar registry above. Same three
    // mutually-exclusive subsets (names / memoize / memoize_ttl), but filtered
    // to rtd-once functions whose Return is grid/numgrid. Installed before any
    // topic can connect so ConnectData can recognize a grid-once topic, the
    // guest->host handler can Store the serialized grid under the right key, and
    // read-time / calc-end expiry know which payloads to age out or clear.
    xll::RtdOnceGridRegistry::Instance().SetFunctionNames(
        { {{range .Functions}}{{if and (eq .Mode "rtd-once") (or (eq .Return "grid") (eq .Return "numgrid"))}}L"{{.Name}}", {{end}}{{end}} },
        { {{range .Functions}}{{if and (eq .Mode "rtd-once") (and (or (eq .Return "grid") (eq .Return "numgrid")) .Memoize)}}L"{{.Name}}", {{end}}{{end}} },
        { {{range .Functions}}{{if and (eq .Mode "rtd-once") (and (or (eq .Return "grid") (eq .Return "numgrid")) .MemoizeTTL)}}{ L"{{.Name}}", {{durationMillis .MemoizeTTL}}ULL }, {{end}}{{end}} }
    );
    {{end}}

    {{if anyRtd .Functions}}
    // plain rtd: register each streaming rtd function's first-paint placeholder
    // (resolved loading_placeholder, default #GETTING_DATA) BEFORE any topic can
    // connect, so ConnectData surfaces it as the initial value instead of the
    // legacy "Connecting..." text. The streaming wrapper still returns live
    // values verbatim; only this connect-time initial value is governed here.
    xll::RtdPlaceholderRegistry::Instance().Set({
        {{range .Functions}}{{if eq .Mode "rtd"}}{{rtdPlaceholderEntry . $.Rtd}}, {{end}}{{end}}
    });
    {{end}}

    // Register User Functions
{{range $i, $fn := .Functions}}
    {
        // Register {{.Name}}
        // macro:true functions are registered as macro-sheet equivalents ('#',
        // required so the wrapper can call macro-only C-API like xlfGetCell for
        // the caller's number format) and therefore must NOT carry the
        // thread-safe marker '$' — Excel rejects the '#$' combination (the
        // xlfRegister return is xltypeErr and the worksheet name yields #NAME?).
        // caller:true alone does NOT imply '#': xlfCaller is callable from any
        // XLL function, so a caller-without-macro function stays thread-safe.
        ScopedXLOPER12Result xRegId;
        std::wstring typeStr = L"{{if eq .Mode "async"}}>{{end}}{{if and (isRtdLike .Mode) (eq .Return "numgrid")}}{{lookupXllType .Return}}{{else if isRtdLike .Mode}}Q{{else}}{{if ne .Mode "async"}}{{lookupXllType .Return}}{{end}}{{end}}{{range .Args}}{{lookupArgXllType .Type}}{{end}}{{if eq .Mode "async"}}X{{end}}{{if .Macro}}#{{end}}{{if .Volatile}}!{{end}}{{if not .Macro}}${{end}}";

        int regRes = xll::RegisterFunction(
            *xDLL,
            L"{{.Name}}", // Procedure
            typeStr.c_str(), // TypeText
            L"{{.Name}}", // FunctionText
            L"{{range $j, $arg := .Args}}{{$arg.Name}}{{if lt $j (sub (len $fn.Args) 1)}},{{end}}{{end}}", // ArgumentText
            1, // MacroType
            L"{{if .Category}}{{escapeCppString .Category}}{{else}}{{$.ProjectName}}{{end}}", // Category
            L"{{.Shortcut}}", // Shortcut
            L"{{escapeCppString .HelpTopic}}", // HelpTopic
            L"{{escapeCppString .Description}}", // FunctionHelp
            { // ArgumentHelp
                {{range .Args}}L"{{escapeCppString .Description}}",{{end}}
            },
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register function '{{.Name}}'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered function '{{.Name}}' successfully. ID: " + idStr);
        }
    }
{{end}}

    {{if .Commands}}
    // Register XLL Commands (macroType=2). Mirrors the function loop above but
    // with no args/category and a Ctrl+Shift+<letter> shortcut. Command names
    // were registered above so a shortcut-fired proc resolves its name.
    {{end}}
    {{range .Commands}}
    {
        // Register command Cmd_{{.Name}}
        ScopedXLOPER12Result xRegId;
        int regRes = xll::RegisterFunction(
            *xDLL,
            L"Cmd_{{.Name}}", // Procedure (exported symbol)
            L"J", // TypeText: "J" = 4-byte signed int (matches the `int` Cmd_ export return; macroType=2 ignores the value). See §19.2.
            L"{{.Name}}", // FunctionText: name typed in the Alt+F8 dialog
            L"", // ArgumentText: commands take none
            2, // MacroType 2 = command
            L"", // Category (unused for commands)
            L"{{.Shortcut}}", // Shortcut letter -> Ctrl+Shift+<letter>
            L"", // HelpTopic
            L"{{escapeCppString .Description}}", // FunctionHelp
            {}, // ArgumentHelp
            *xRegId // Output ID
        );

        if (regRes != xlretSuccess) {
            SAFE_LOG_ERROR("Failed to register command '{{.Name}}'. Code: " + std::to_string(regRes));
        } else {
            std::string idStr = "Unknown";
            if (xRegId->xltype == xltypeNum) idStr = std::to_string((int)xRegId->val.num);
            SAFE_LOG_INFO("Registered command '{{.Name}}' successfully. ID: " + idStr);
        }
    }
    {{end}}
    {{if .Ribbon.Enabled}}
    // ---- Ribbon COM add-in bootstrap. Graceful degradation: any failure
    // logs a warning and leaves functions/commands fully operational. ----
    // The connect (step 4) needs the in-process Application object, only
    // reachable via the EXCEL7 child window — which does NOT exist when the
    // add-in is loaded with no workbook open. The xlAutoOpen attempt passes
    // allowBounce=true so GetExcelApplicationOrBounce synchronously creates a
    // temporary workbook (Excel-DNA's mechanism) to materialize that window,
    // letting the connect succeed even with no document open. The connection
    // binds to the Application and survives the temp workbook closing.
    XLL_SAFE_BLOCK_BEGIN
        // First (and normally only) attempt on the STA thread, with the
        // temp-workbook bounce enabled. The calc-end handler is a defensive
        // fallback for the rare case the bounce itself fails.
        TryConnectRibbon("xlAutoOpen", /*allowBounce=*/true);
    XLL_SAFE_BLOCK_END_CONTINUE
    {{end}}

    {{if and .Rtd.Enabled .Rtd.ThrottleInterval}}
    XLL_SAFE_BLOCK_BEGIN
        // rtd.throttle_interval (xll.yaml): explicit opt-in to lower/raise
        // Application.RTD.ThrottleInterval (registry-persisted, per-user;
        // Excel default is 2000ms). Often fails here (no workbook yet) —
        // the calc-end callbacks below retry until a workbook exists.
        TryApplyRtdThrottle("xlAutoOpen");
    XLL_SAFE_BLOCK_END_CONTINUE
    {{end}}

        SAFE_LOG_INFO("xlAutoOpen: Initialization complete. Returning 1.");
        return 1;
    XLL_SAFE_BLOCK_END(0)
}

// Event Handlers
{{range .Events}}
extern "C" __declspec(dllexport) void __stdcall {{.Handler}}() {
    {{if and $.Rtd.Enabled $.Rtd.ThrottleInterval}}
    // Calc-end runs on the main STA thread with a workbook open — the
    // reliable moment to apply rtd.throttle_interval (one-shot, see above).
    TryApplyRtdThrottle("calc event");
    {{end}}
    {{if $.Ribbon.Enabled}}
    // Defensive fallback retry hook for the ribbon COMAddIns connect (idempotent;
    // a no-op once connected). The xlAutoOpen temp-workbook bounce normally
    // connects already; this only matters if that bounce failed. No bounce here
    // (allowBounce defaults false): a workbook exists by the time calc runs.
    TryConnectRibbon("calc event");
    {{end}}
    {{if eq .Type "CalculationEnded"}}
    // A user-renamed CalculationEnded handler still owns ALL system-side
    // calc-end work: RefCache clear, rtd-once ClearNonMemoized, the date
    // auto-format drain (DrainAndApplyDateFormats), AND the MSG_CALCULATION_ENDED
    // round-trip that ultimately invokes the user's Go handler ({{.Handler}}).
    // HandleCalculationEnded() does all of this. Without this call the drain
    // never runs — dates returned by UDFs stay as raw serials and the user's
    // own Go handler never fires. (Regression fixed: previously this named-event
    // stub only logged, and the built-in CalculationEnded() macro that calls
    // HandleCalculationEnded was suppressed whenever a user handler existed.)
    HandleCalculationEnded();
    {{else}}
    std::vector<uint8_t> respBuf;
    // Construct Request (Event)
    // Currently not fully implemented for named events
    SAFE_LOG_INFO("Event {{.Type}} triggered");
    {{end}}
}
{{end}}

{{if hasEvent "CalculationEnded" .Events}}
// User defined handler exists
{{else}}
extern "C" __declspec(dllexport) void __stdcall CalculationEnded() {
    {{if and .Rtd.Enabled .Rtd.ThrottleInterval}}
    TryApplyRtdThrottle("calc end");
    {{end}}
    {{if .Ribbon.Enabled}}
    // Defensive fallback retry hook for the ribbon COMAddIns connect (idempotent;
    // a no-op once connected). The xlAutoOpen temp-workbook bounce normally
    // connects already; this only matters if that bounce failed. No bounce here
    // (allowBounce defaults false): a workbook exists by the time calc runs.
    TryConnectRibbon("calc end");
    {{end}}
    HandleCalculationEnded();
}
{{end}}

// Calc-end deferred command runner. Registered as a macro (macroType=2) in
// xlAutoOpen and scheduled via xlcOnTime from HandleCalculationEnded. Excel
// dispatches it on the STA thread at an idle point — OUTSIDE the
// xleventCalculationEnded callback and after any in-flight recalc / rtd-once
// topic teardown has settled — which is where it is safe to run the cell
// mutations (xlSet) and the date auto-format (COM Range.NumberFormat applied
// off-selection; see src/xll_date_format.cpp). The exported symbol name
// MUST match xll::DeferredRunnerMacroName(). Returns short (TypeText "I").
extern "C" __declspec(dllexport) short __stdcall __xllgen_RunDeferredCalcEnd() {
    XLL_SAFE_BLOCK_BEGIN
        xll::RunDeferredCalcEndCommands();
    XLL_SAFE_BLOCK_END(0)
    return 1;
}

// User Functions
{{range $i, $fn := .Functions}}
extern "C" __declspec(dllexport) {{if eq .Mode "async"}}void{{else}}{{if and (isRtdLike .Mode) (eq .Return "numgrid")}}{{lookupCppType .Return}}{{else if isRtdLike .Mode}}LPXLOPER12{{else}}{{lookupCppType .Return}}{{end}}{{end}} __stdcall {{.Name}}({{range $j, $arg := .Args}}{{lookupCppArgType $arg.Type}} {{$arg.Name}}{{if lt $j (sub (len $fn.Args) 1)}}, {{end}}{{end}}{{if eq .Mode "async"}}{{if .Args}}, {{end}}LPXLOPER12 asyncHandle{{end}}) {
    // Probe-unload guard: OnAutoClose frees and nulls g_phost (xll_ipc.h:
    // `#define g_host (*g_phost)`). A stale Excel calc thread can still enter
    // a registered UDF after probe-unload; dereferencing g_host (e.g.
    // GetZeroCopySlot below) would crash on a null deref. Bail out early with
    // the same error value the SHM-failure path returns. Mirrors the
    // g_isUnloading guard convention used in xll_worker.cpp / lifecycle.
    if (g_phost == nullptr) {
        {{if eq .Mode "async"}}
        // Async UDFs return void; Excel was told the result would arrive via
        // xlAsyncReturn. With the host gone there is nothing to send — bail.
        return;
        {{else if eq .Return "numgrid"}}
        // FP12* (K%) functions cannot return an XLOPER12 sentinel; a null
        // FP12* is the established error convention (NumGridToFP12's own
        // error paths return nullptr; Excel renders #NUM!). This covers BOTH
        // sync numgrid AND rtd-once numgrid — both export FP12* (K%), so the
        // &g_xlErrValue (LPXLOPER12) sentinel below would be a type mismatch.
        return nullptr;
        {{else}}
        // Sync (scalar/grid), RTD and scalar/grid rtd-once wrappers all return
        // LPXLOPER12; surface the shared error sentinel, identical to the
        // res.HasError() path below.
        return &g_xlErrValue;
        {{end}}
    }

    SAFE_LOG_DEBUG("Func Entry: {{.Name}}");

    {{if eq .Mode "rtd"}}
    // RTD Wrapper Implementation
    static thread_local XLOPER12 xRes;

    // Convert arguments to strings for RTD Topics
    // Topic 0: Function Name
    std::wstring t0 = L"{{.Name}}";

    {{range $j, $arg := .Args}}
    std::wstring t{{add $j 1}};
    {
        {{if eq .Type "int"}}
        t{{add $j 1}} = std::to_wstring({{.Name}});
        {{else if eq .Type "float"}}
        t{{add $j 1}} = std::to_wstring({{.Name}});
        {{else if eq .Type "bool"}}
        t{{add $j 1}} = {{.Name}} ? L"TRUE" : L"FALSE";
        {{else if eq .Type "string"}}
        if ({{.Name}}->xltype == xltypeStr) {
            t{{add $j 1}} = PascalToWString({{.Name}}->val.str);
        }
        {{else if eq .Type "date"}}
        // date rides the double path (ArgCppType "double", passed by value): the
        // Excel serial IS the topic-identity, so stringify it as a plain scalar.
        // The Go dispatch parses it back via server.SerialToTime(ParseFloat(...)).
        t{{add $j 1}} = std::to_wstring({{.Name}});
        {{else}}
        // Composite arg (grid/numgrid/range/any): content-hash payload path
        // (AGENTS.md §19.3). The topic carries only the content-hash token; the
        // serialized payload travels once per calc cycle over MSG_SETREFCACHE
        // and the Go dispatch resolves token -> payload from its RefCache.
        {{if eq .Type "numgrid"}}
        std::string tok{{add $j 1}} = xll::ContentHashTokenFP12({{.Name}});
        {{else if eq .Type "grid"}}
        std::string tok{{add $j 1}} = xll::ContentHashToken('g', {{.Name}});
        {{else if eq .Type "range"}}
        std::string tok{{add $j 1}} = xll::ContentHashToken('r', {{.Name}});
        {{else}}
        std::string tok{{add $j 1}} = xll::ContentHashToken('a', {{.Name}});
        {{end}}
        {
            // Build a SetRefCacheRequest{ key=token, val=Any(payload) } and
            // ship it ONCE per cycle (SendRefCachePayloadOnce dedups on the
            // token) BEFORE xlfRtd so the server has the payload cached before
            // ConnectData fires the handler.
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(tok{{add $j 1}});
            bool rcOk = true;
            {{if eq .Type "grid"}}
            auto rcInner = xll::ConvertGridArg({{.Name}}, rcb, &rcOk);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Grid, rcInner.Union());
            {{else if eq .Type "numgrid"}}
            auto rcInner = ConvertNumGrid({{.Name}}, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::NumGrid, rcInner.Union());
            {{else if eq .Type "range"}}
            auto rcInner = ConvertRange({{.Name}}, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Range, rcInner.Union());
            {{else}}
            // any: ConvertAny already produces an Offset<protocol::Any>.
            auto rcAny = ConvertAny({{.Name}}, rcb);
            {{end}}
            if (!rcOk) {
                // Coerce of the reference failed (xlretUncalced etc.) — do NOT
                // ship a degenerate payload under this token; the Go dispatch
                // will miss and push an explicit error to the topic.
                SAFE_LOG_WARN("RTD {{$fn.Name}}: composite arg coerce failed; skipping payload ship for token " + tok{{add $j 1}});
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                if (!xll::SendRefCachePayloadOnce(tok{{add $j 1}}, rcb.GetBufferPointer(), rcb.GetSize())) {
                    SAFE_LOG_WARN("RTD {{$fn.Name}}: failed to ship composite arg payload for token " + tok{{add $j 1}});
                }
            }
        }
        t{{add $j 1}} = StringToWString(tok{{add $j 1}});
        {{end}}
    }
    {{end}}

    // Call Excel RTD(ProgID, Server, Topic1, Topic2...)
    static std::wstring wProgID = L"{{$.Rtd.ProgID}}";
    
    int xlRet = xll::CallExcel(xlfRtd, &xRes, 
        wProgID.c_str(), 
        L"", 
        t0.c_str() 
        {{range $j, $arg := .Args}}, t{{add $j 1}}.c_str(){{end}}
    );

    if (xlRet != xlretSuccess) {
        SAFE_LOG_ERROR("xlfRtd failed for {{.Name}}. Return code: " + std::to_string(xlRet));
        xRes.xltype = xltypeErr;
        xRes.val.err = xlerrValue;
    } else {
        std::string valStr = "Unknown";
        if (xRes.xltype & xltypeStr) valStr = WideToUtf8(PascalToWString(xRes.val.str));
        else if (xRes.xltype & xltypeNum) valStr = std::to_string(xRes.val.num);
        else if (xRes.xltype & xltypeBool) valStr = xRes.val.xbool ? "TRUE" : "FALSE";
        else if (xRes.xltype & xltypeErr) valStr = "Error:" + std::to_string(xRes.val.err);
        
        SAFE_LOG_DEBUG("xlfRtd called for {{.Name}}. Result type: " + std::to_string(xRes.xltype) + ", Value: " + valStr);
    }

    return &xRes;

    {{else if eq .Mode "rtd-once"}}
    // rtd-once Wrapper Implementation.
    //
    // Builds the same topic strings as plain rtd (t0=function name, t1.. =
    // stringified scalar args). The lifecycle (AGENTS.md §19.3):
    //   1. Compute the key. If a completed result is already cached
    //      (RtdOnceResults), return it WITHOUT calling xlfRtd. The cell then
    //      holds no RTD reference, so Excel calls DisconnectData at end of
    //      calc and the topic is torn down (Go-side unsubscribe via the
    //      existing path).
    //   2. Otherwise call xlfRtd. Excel calls ConnectData(topicID, strings),
    //      which registers the topicID->key mapping and returns the
    //      #GETTING_DATA placeholder. The Go server runs the handler once and
    //      pushes the result; ProcessRtdUpdate caches it under the key and
    //      recalcs the cell, which re-enters this wrapper and hits the cache.

    // Topic 0: Function Name
    std::wstring t0 = L"{{.Name}}";

    {{range $j, $arg := .Args}}
    std::wstring t{{add $j 1}};
    {{if and (ne .Type "int") (ne .Type "float") (ne .Type "bool") (ne .Type "string") (ne .Type "date")}}
    // Composite-arg payloads, built now (for the content hash that goes into
    // the once-key) but SHIPPED only on a cache miss (just before xlfRtd).
    std::vector<uint8_t> refPayload{{add $j 1}};
    std::string refTok{{add $j 1}};
    {{end}}
    {
        {{if eq .Type "int"}}
        t{{add $j 1}} = std::to_wstring({{.Name}});
        {{else if eq .Type "float"}}
        t{{add $j 1}} = std::to_wstring({{.Name}});
        {{else if eq .Type "bool"}}
        t{{add $j 1}} = {{.Name}} ? L"TRUE" : L"FALSE";
        {{else if eq .Type "string"}}
        if ({{.Name}}->xltype == xltypeStr) {
            t{{add $j 1}} = PascalToWString({{.Name}}->val.str);
        }
        {{else if eq .Type "date"}}
        // date rides the double path (ArgCppType "double", by value): stringify
        // the serial as a plain scalar. It flows into the once-key exactly like
        // any other scalar; the Go dispatch parses it back via
        // server.SerialToTime(ParseFloat(...)).
        t{{add $j 1}} = std::to_wstring({{.Name}});
        {{else}}
        // Composite arg (grid/numgrid/range/any): content-hash payload path.
        // The token is content-addressed, so it flows into the once-key below
        // (MakeRtdOnceKey) and makes memoization content-addressed for free:
        // the same input grid hits the cache; an edited grid yields a new
        // token -> new key -> fresh compute (AGENTS.md §19.3).
        {{if eq .Type "numgrid"}}
        refTok{{add $j 1}} = xll::ContentHashTokenFP12({{.Name}});
        {{else if eq .Type "grid"}}
        refTok{{add $j 1}} = xll::ContentHashToken('g', {{.Name}});
        {{else if eq .Type "range"}}
        refTok{{add $j 1}} = xll::ContentHashToken('r', {{.Name}});
        {{else}}
        refTok{{add $j 1}} = xll::ContentHashToken('a', {{.Name}});
        {{end}}
        {
            flatbuffers::FlatBufferBuilder rcb(1024);
            auto rcKey = rcb.CreateString(refTok{{add $j 1}});
            bool rcOk = true;
            {{if eq .Type "grid"}}
            auto rcInner = xll::ConvertGridArg({{.Name}}, rcb, &rcOk);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Grid, rcInner.Union());
            {{else if eq .Type "numgrid"}}
            auto rcInner = ConvertNumGrid({{.Name}}, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::NumGrid, rcInner.Union());
            {{else if eq .Type "range"}}
            auto rcInner = ConvertRange({{.Name}}, rcb);
            auto rcAny = protocol::CreateAny(rcb, protocol::AnyValue::Range, rcInner.Union());
            {{else}}
            auto rcAny = ConvertAny({{.Name}}, rcb);
            {{end}}
            if (!rcOk) {
                // Coerce failed: leave refPayload empty — the ship step below
                // skips empty payloads and the Go dispatch surfaces an explicit
                // miss error instead of a silent degenerate grid.
                SAFE_LOG_WARN("rtd-once {{$fn.Name}}: composite arg coerce failed; skipping payload for token " + refTok{{add $j 1}});
            } else {
                auto rcReq = protocol::CreateSetRefCacheRequest(rcb, rcKey, rcAny);
                rcb.Finish(rcReq);
                refPayload{{add $j 1}}.assign(rcb.GetBufferPointer(), rcb.GetBufferPointer() + rcb.GetSize());
            }
        }
        t{{add $j 1}} = StringToWString(refTok{{add $j 1}});
        {{end}}
    }
    {{end}}

    {
        std::vector<std::wstring> topics = { t0 {{range $j, $arg := .Args}}, t{{add $j 1}}{{end}} };
        std::wstring onceKey = xll::MakeRtdOnceKey(topics);

        // 1. Cache hit: return the completed value directly (no xlfRtd).
        {{if or (eq .Return "grid") (eq .Return "numgrid")}}
        // grid-once cache hit: the host stored the WHOLE serialized
        // protocol::RtdOnceGridResult buffer under this key (Task 4). Recover
        // the grid from the Any union and spill it. The null-union guard mirrors
        // the SYNC grid path: a null pointer flows straight into the converter,
        // which yields the same error/empty result it produces for a null
        // resp->result() (GridToXLOPER12 -> #VALUE!, NumGridToFP12 -> 0x0).
        {
            std::vector<uint8_t> gbytes;
            if (xll::RtdOnceGridRegistry::Instance().TryGet(onceKey, &gbytes)) {
                auto* r = flatbuffers::GetRoot<protocol::RtdOnceGridResult>(gbytes.data());
                const protocol::Any* any = r ? r->value() : nullptr;
                {{if eq .Return "numgrid"}}
                const protocol::NumGrid* ng = any ? any->val_as_NumGrid() : nullptr;
                return NumGridToFP12(ng);
                {{else}}
                const protocol::Grid* gr = any ? any->val_as_Grid() : nullptr;
                // grid-once spill: schedule date auto-format for any Date cells
                // before materializing. The Any wrapper carries the dates.
