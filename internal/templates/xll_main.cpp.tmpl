    //    server has them cached BEFORE ConnectData fires the handler, then
    //    issue xlfRtd. ConnectData returns #GETTING_DATA for this rtd-once
    //    topic (it recognizes the function name and substitutes the placeholder
    //    for the plain-rtd "Connecting..." BSTR).
    {{range $j, $arg := .Args}}{{if and (ne .Type "int") (ne .Type "float") (ne .Type "bool") (ne .Type "string") (ne .Type "date")}}
    if (!refPayload{{add $j 1}}.empty()) {
        if (!xll::SendRefCachePayloadOnce(refTok{{add $j 1}}, refPayload{{add $j 1}}.data(), refPayload{{add $j 1}}.size())) {
            SAFE_LOG_WARN("rtd-once {{$fn.Name}}: failed to ship composite arg payload for token " + refTok{{add $j 1}});
        }
    }
    {{end}}{{end}}
    {
        static thread_local XLOPER12 xRes;
        static std::wstring wProgID = L"{{$.Rtd.ProgID}}";

        int xlRet = xll::CallExcel(xlfRtd, &xRes,
            wProgID.c_str(),
            L"",
            t0.c_str()
            {{range $j, $arg := .Args}}, t{{add $j 1}}.c_str(){{end}}
        );

        if (xlRet != xlretSuccess) {
            SAFE_LOG_ERROR("xlfRtd failed for rtd-once {{.Name}}. Return code: " + std::to_string(xlRet));
            {{if eq .Return "numgrid"}}
            (void)xRes;
            return NumGridToFP12(nullptr);
            {{else}}
            return &g_xlErrValue;
            {{end}}
        }
        {{if eq .Return "numgrid"}}
        // numgrid exports FP12* (K%), so it cannot carry a cell error and thus
        // cannot use the #GETTING_DATA sentinel the scalar/grid paths return on a
        // cache miss. Emit an empty 0x0 FP12 placeholder (NumGridToFP12(nullptr))
        // instead — the readiness push from RunOnceGrid recalcs the cell, which
        // then hits the grid registry above and spills the real numgrid.
        (void)xRes;
        return NumGridToFP12(nullptr);
        {{else}}
        // First paint on a cache miss: return the resolved loading placeholder,
        // NOT xlfRtd's raw synchronous result (xRes) — for a brand-new topic that
        // is #N/A, which is what the cell would otherwise flash before the result
        // push arrives. The xlfRtd call above already wired the RTD subscription,
        // so the eventual result push recalcs this cell; it then hits the
        // RtdOnceRegistry cache short-circuit above and returns the real value.
        // The placeholder is #GETTING_DATA by default (loading_placeholder:
        // "getting_data"/""), #N/A ("na"), or verbatim text (any other value).
        // The error sentinels are process-global (no xlbitDLLFree, mirror
        // g_xlErrValue); custom text uses NewExcelString (DLL-owned, reclaimed by
        // xlAutoFree12).
        (void)xRes;
        {{rtdPlaceholderReturn . $.Rtd}}
        {{end}}
    }

    {{else}}
    {{/* Determine Cache Configuration */}}
    {{ $cacheEnabled := $.Cache.Enabled }}
    {{ $ttl := $.Cache.TTL }}
    {{ if .Cache }}
        {{ if .Cache.Enabled }}{{ $cacheEnabled = derefBool .Cache.Enabled }}{{ end }}
        {{ if .Cache.TTL }}{{ $ttl = .Cache.TTL }}{{ end }}
    {{ end }}

    {{if and $cacheEnabled (not .Async)}}
    // Cache Lookup
    xll::CacheConfig cacheConfig;
    cacheConfig.enabled = true;
    cacheConfig.ttl = std::chrono::milliseconds({{parseDurationToMs $ttl}});
    cacheConfig.jitter = std::chrono::milliseconds({{parseDurationToMs $.Cache.Jitter}});

    // Prepare temporary XLOPERs for non-pointer arguments
    std::vector<XLOPER12> tempArgs({{len .Args}});
    std::vector<LPXLOPER12> cacheArgs;
    cacheArgs.reserve({{len .Args}});

    {{range $j, $arg := .Args}}
    {
        XLOPER12& xArg = tempArgs[{{$j}}];
        {{if eq .Type "int"}}
        xArg.xltype = xltypeInt;
        xArg.val.w = {{.Name}};
        cacheArgs.push_back(&xArg);
        {{else if eq .Type "float"}}
        xArg.xltype = xltypeNum;
        xArg.val.num = {{.Name}};
        cacheArgs.push_back(&xArg);
        {{else if eq .Type "bool"}}
        xArg.xltype = xltypeBool;
        xArg.val.xbool = {{.Name}} ? 1 : 0;
        cacheArgs.push_back(&xArg);
        {{else if eq .Type "string"}}
        // A `string` arg is registered LPXLOPER12 (ArgCppType), so {{.Name}} is
        // already a well-formed Excel-owned XLOPER12* (xltypeStr / Missing / Err
        // for an empty cell). Push it directly like grid/range/any —
        // MakeCacheKey's SerializeXLOPER content-hashes xltypeStr via
        // PascalToWString, so the key already tracks the string's content. (The
        // old branch called CreateStringXLOPER, which is defined nowhere and so
        // never compiled whenever a cache-enabled function had a string arg.)
        (void)xArg;
        cacheArgs.push_back({{.Name}});
        {{else if eq .Type "date"}}
        // date rides ArgCppType "double" (Excel passes the serial by value), so
        // it is NOT an LPXLOPER12 — a blanket (LPXLOPER12){{.Name}} cast is
        // ill-formed and fails to compile. Wrap the serial in a temp xltypeNum
        // XLOPER12 (identical to the float branch) so the cache key reflects the
        // date's value.
        xArg.xltype = xltypeNum;
        xArg.val.num = {{.Name}};
        cacheArgs.push_back(&xArg);
        {{else if eq .Type "numgrid"}}
        // numgrid is an FP12* (not an XLOPER12), so it cannot enter the
        // LPXLOPER12 cacheArgs vector — reinterpret-casting FP12* to LPXLOPER12
        // would make MakeCacheKey read the FP12 double payload as an XLOPER
        // (garbage xltype -> silent mis-key or a bogus lpmref deref/AV). Its
        // content hash is folded into cacheKey AFTER MakeCacheKey below via the
        // same ContentHashTokenFP12 the RTD path uses (§19.3).
        (void)xArg;
        {{else}}
        // grid/range/any are already LPXLOPER12; MakeCacheKey content-hashes
        // them (SerializeXLOPER for value arrays, GetOrComputeRefHash for the
        // U-passed range references), so the identity cast is well-formed and
        // the cache key already tracks their content.
        cacheArgs.push_back((LPXLOPER12){{.Name}});
        {{end}}
    }
    {{end}}

    std::string cacheKey = xll::MakeCacheKey("{{.Name}}", cacheArgs);
    {{range .Args}}{{if eq .Type "numgrid"}}
    // Fold this numgrid (FP12*) arg's content hash into the cache key. A numgrid
    // arg cannot enter the LPXLOPER12 cacheArgs vector, so MakeCacheKey never
    // saw it; append the same ContentHashTokenFP12 token the RTD content-hash
    // path uses (§19.3) so distinct grids get distinct keys and identical grids
    // share one. Without this the numgrid arg would be invisible to the key.
    cacheKey += "|numgrid:" + xll::ContentHashTokenFP12({{.Name}});
    {{end}}{{end}}

    // (No temporary string allocations to clean up: string cache args are the
    // Excel-owned XLOPER12* pushed directly above, not DLL-allocated copies.)

    std::vector<uint8_t> cachedData;
    if (xll::CacheManager::Instance().Get(cacheKey, cachedData)) {
        // Deserialize response
        auto resp = flatbuffers::GetRoot<ipc::{{.Name}}Response>(cachedData.data());

{{template "returnConversion" (dict "Indent" "        " "Ret" .Return)}}
    }
    {{end}}

    // NOTE: 'slot' is declared here using GetZeroCopySlot().
    // SHMAllocator uses it for Zero-Copy Write of the Request.
    auto slot = g_host.GetZeroCopySlot();
    SHMAllocator allocator(slot.GetReqBuffer(), slot.GetMaxReqSize());
    flatbuffers::FlatBufferBuilder builder(slot.GetMaxReqSize(), &allocator, false);

    // Arguments
    {{range $j, $arg := .Args}}
    {{if eq .Type "string"}}
    auto arg{{$j}} = builder.CreateString(({{.Name}}->xltype == xltypeStr) ? ConvertExcelString({{.Name}}->val.str) : "");
    {{else if eq .Type "grid"}}
    // A `grid` arg is registered `U` (§19.2), so Excel passes a REFERENCE
    // (xltypeRef/SRef) for a range like A1:B2 — NOT an xltypeMulti. Plain
    // ConvertGrid only understands xltypeMulti and would coin a degenerate 1x1
    // Nil grid for a reference (the Go handler then reads an empty grid →
    // SumGrid==0). Route through xll::ConvertGridArg, which xlCoerce's the ref
    // to its cell VALUES first (mirrors the rtd/rtd-once content-hash path).
    // An array LITERAL ({1,2;3,4}) already arrives as xltypeMulti and passes
    // through unchanged.
    bool gridCoerceOk{{$j}} = true;
    auto arg{{$j}} = xll::ConvertGridArg({{.Name}}, builder, &gridCoerceOk{{$j}});
    if (!gridCoerceOk{{$j}}) {
        // xlCoerce failed (xlretUncalced mid-calc, cross-sheet restriction, …).
        // Do NOT ship a degenerate 1x1 Nil grid — surface the same error the
        // SHM-failure path below returns so the cell shows #VALUE! and Excel
        // re-drives the UDF on the next recalc pass (precedents calc first for
        // a `$`-registered function, so this is genuinely exceptional).
        SAFE_LOG_WARN("{{$fn.Name}}: grid arg {{.Name}} coerce failed; returning error sentinel");
        {{if eq $fn.Mode "async"}}
        XLOPER12 xErr{}; // zero-init: Excel reads only val.err for xltypeErr; keeps padding deterministic
        xErr.xltype = xltypeErr;
        xErr.val.err = xlerrValue;
        xll::CallExcel(xlAsyncReturn, nullptr, (LPXLOPER12)asyncHandle, &xErr);
        return;
        {{else}}
        return &g_xlErrValue;
        {{end}}
    }
    {{else if eq .Type "numgrid"}}
    auto arg{{$j}} = ConvertNumGrid({{.Name}}, builder);
    {{else if eq .Type "range"}}
    auto arg{{$j}} = ConvertRange({{.Name}}, builder);
    {{else if eq .Type "any"}}
    auto arg{{$j}} = ConvertAny({{.Name}}, builder);
    {{end}}
    {{end}}

    {{if .Caller}}
    flatbuffers::Offset<protocol::Range> caller_off = 0;
    {
        ScopedXLOPER12 xCaller;
        if (xll::CallExcel(xlfCaller, xCaller) == xlretSuccess) {
            std::string callerFormat = "";
            {{if .Macro}}
            // macro:true → the function is a macro-sheet equivalent ('#'), so
            // the wrapper may call the macro-only xlfGetCell to fetch the
            // caller's number-format string (type 7) into Range.Format().
            XLOPER12 xType; xType.xltype = xltypeInt; xType.val.w = 7;
            // ScopedXLOPER12Result (not ScopedXLOPER12): xlfGetCell returns an
            // Excel-allocated xltypeStr that must be released with xlFree —
            // the Result destructor does that; plain ScopedXLOPER12 leaked it
            // on every macro caller-aware call.
            ScopedXLOPER12Result xFormat;
            if (xll::CallExcel(xlfGetCell, xFormat, &xType, xCaller) == xlretSuccess) {
                if (xFormat.get()->xltype == xltypeStr) {
                        callerFormat = ConvertExcelString(xFormat.get()->val.str);
                }
            }
            {{end}}
            // caller:true without macro:true is position-only — xlfCaller is
            // callable from any XLL function, but xlfGetCell is not, so the
            // number format is left empty here (Range.Format() == "").
            caller_off = ConvertRange(xCaller.get(), builder, callerFormat);
        }
    }
    {{end}}

    {{if eq .Mode "async"}}
    auto asyncHandle_vec = builder.CreateVector((const uint8_t*)asyncHandle, sizeof(XLOPER12));
    {{end}}

    ipc::{{.Name}}RequestBuilder reqBuilder(builder);
    {{range $j, $arg := .Args}}
    {{if or (eq .Type "int") (eq .Type "float") (eq .Type "bool") (eq .Type "date")}}
    {{/* date rides the double request path: the C param is a `double` (ArgCppType),
         so it is added DIRECTLY like a float/int scalar — NO arg<N> offset is
         created for it in the arg-decode loop above. */}}
    reqBuilder.add_{{.Name}}({{if eq .Type "bool"}}({{.Name}} != 0){{else}}{{.Name}}{{end}});
    {{else}}
    reqBuilder.add_{{.Name}}(arg{{$j}});
    {{end}}
    {{end}}

    {{if .Caller}}
    if (caller_off.o != 0) reqBuilder.add_caller(caller_off);
    {{end}}
    {{if eq .Mode "async"}}
    reqBuilder.add_async_handle(asyncHandle_vec);
    {{end}}

    auto req = reqBuilder.Finish();
    builder.Finish(req);

    {{if eq .Mode "async"}}
    // Async Send
    SAFE_LOG_DEBUG("Async Send Start: {{.Name}}");
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType){{add MsgUserStart $i}}, {{if .Timeout}}{{parseTimeout .Timeout 2000}}{{else}}{{parseTimeout $.Server.AsyncAckTimeout 2000}}{{end}});
    SAFE_LOG_DEBUG("Async Send End: {{.Name}}");

    if (res.HasError()) {
            std::string err = "Async send failed: " + SHMErrorToString(res.GetError());
            SAFE_LOG_ERROR(err);
            XLOPER12 xErr;
            xErr.xltype = xltypeErr;
            xErr.val.err = xlerrValue;
            xll::CallExcel(xlAsyncReturn, nullptr, (LPXLOPER12)asyncHandle, &xErr);
            return;
    }
    SAFE_LOG_DEBUG("Func Exit: {{.Name}}");
    return;
    {{else}}
    // Sync Send
    auto res = slot.Send(-((int)builder.GetSize()), (shm::MsgType){{add MsgUserStart $i}}, {{if .Timeout}}{{parseTimeout .Timeout 2000}}{{else}}{{parseTimeout $.Server.Timeout 2000}}{{end}});

    if (res.HasError()) {
            {{if eq .Return "numgrid"}}
            // FP12* (K%) error convention: null FP12* (matches NumGridToFP12).
            return nullptr;
            {{else}}
            return &g_xlErrValue;
            {{end}}
    }

    auto resp = flatbuffers::GetRoot<ipc::{{.Name}}Response>(slot.GetRespBuffer());

    {{if and $cacheEnabled (ne .Mode "async")}}
    // Store in cache
    {
        int32_t respSize = slot.GetRespSize();
        if (respSize > 0) {
                std::vector<uint8_t> response(slot.GetRespBuffer(), slot.GetRespBuffer() + respSize);
                xll::CacheManager::Instance().Put(cacheKey, response, cacheConfig);
        }
    }
    {{end}}

{{template "returnConversion" (dict "Indent" "    " "Ret" .Return)}}
    {{end}}
    {{end}}
}
{{end}}

{{if .Commands}}
// XLL command procedures (macroType=2). Invoked via Ctrl+Shift shortcut or a
// typed name in the Alt+F8 dialog; ribbon clicks go through
// RibbonAddIn::Invoke instead. Same fire-and-forget dispatch — a command
// proc must never block Excel's UI thread waiting on the Go handler.
{{range .Commands}}
extern "C" __declspec(dllexport) int __stdcall Cmd_{{.Name}}() {
    XLL_SAFE_BLOCK_BEGIN
        xll::ribbon::SendCommandInvoke("{{.Name}}", "");
    XLL_SAFE_BLOCK_END(0)
    return 1;
}
{{end}}
{{end}}
